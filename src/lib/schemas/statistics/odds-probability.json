{"id":"odds-probability","slug":"odds-probability","name":"Odds Probability Calculator","category":"statistics","icon":"🎲","description":"Convert between odds (for:against) and probability. Calculate implied probability from betting odds.","tags":["odds","probability","betting","statistics"],"fields":[{"id":"oddsFor","label":"Odds For","type":"number","defaultValue":3,"constraint":{"min":0.01,"step":1}},{"id":"oddsAgainst","label":"Odds Against","type":"number","defaultValue":2,"constraint":{"min":0.01,"step":1}},{"id":"probability","label":"Probability P(A)","type":"computed","precision":6},{"id":"percentage","label":"Percentage (%)","type":"computed","precision":4},{"id":"decimalOdds","label":"Decimal Odds","type":"computed","precision":4},{"id":"complement","label":"P(not A)","type":"computed","precision":6}],"groups":[{"id":"inputs","label":"Odds (For : Against)","fields":["oddsFor","oddsAgainst"]},{"id":"outputs","label":"Probability","fields":["probability","percentage","decimalOdds","complement"]}],"formulas":{"probability":"oddsFor/(oddsFor+oddsAgainst)","percentage":"oddsFor/(oddsFor+oddsAgainst)*100","decimalOdds":"(oddsFor+oddsAgainst)/oddsFor","complement":"oddsAgainst/(oddsFor+oddsAgainst)"},"examples":[{"label":"3:2 odds","inputs":{"oddsFor":3,"oddsAgainst":2}},{"label":"1:1 (evens)","inputs":{"oddsFor":1,"oddsAgainst":1}},{"label":"1:3 (underdog)","inputs":{"oddsFor":1,"oddsAgainst":3}}]}
