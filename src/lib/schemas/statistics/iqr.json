{"id":"iqr","slug":"interquartile-range","name":"Interquartile Range Calculator","category":"statistics","icon":"IQR","description":"Calculate the Interquartile Range (IQR) and identify outlier boundaries using 5 sorted values.","tags":["IQR","interquartile range","statistics","outliers"],"fields":[{"id":"q1","label":"Q1 (25th percentile)","type":"number","defaultValue":25},{"id":"q3","label":"Q3 (75th percentile)","type":"number","defaultValue":75},{"id":"iqr","label":"IQR","type":"computed","precision":4,"helpText":"Q3 - Q1"},{"id":"lowerFence","label":"Lower Fence","type":"computed","precision":4,"helpText":"Q1 - 1.5 × IQR"},{"id":"upperFence","label":"Upper Fence","type":"computed","precision":4,"helpText":"Q3 + 1.5 × IQR"},{"id":"midpoint","label":"Midpoint (Q2 estimate)","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Quartiles","fields":["q1","q3"]},{"id":"outputs","label":"IQR & Fences","fields":["iqr","lowerFence","upperFence","midpoint"]}],"formulas":{"iqr":"q3 - q1","lowerFence":"q1 - 1.5*(q3-q1)","upperFence":"q3 + 1.5*(q3-q1)","midpoint":"(q1+q3)/2"},"examples":[{"label":"Q1=25, Q3=75","inputs":{"q1":25,"q3":75}},{"label":"Q1=10, Q3=40","inputs":{"q1":10,"q3":40}}]}
