{"id":"mean-median-mode","slug":"mean-median-mode-calculator","name":"Mean Median Mode Calculator","category":"statistics","icon":"📊","description":"Find the mean, range, minimum, and maximum of up to 5 data values. Use sorted input for median.","tags":["mean","median","mode","statistics","central tendency"],"fields":[{"id":"x1","label":"Value 1","type":"number","defaultValue":4},{"id":"x2","label":"Value 2","type":"number","defaultValue":7},{"id":"x3","label":"Value 3","type":"number","defaultValue":13},{"id":"x4","label":"Value 4","type":"number","defaultValue":7},{"id":"x5","label":"Value 5","type":"number","defaultValue":3},{"id":"mean","label":"Mean","type":"computed","precision":4},{"id":"minVal","label":"Minimum","type":"computed","precision":4},{"id":"maxVal","label":"Maximum","type":"computed","precision":4},{"id":"range","label":"Range","type":"computed","precision":4},{"id":"sum","label":"Sum","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Data Values","fields":["x1","x2","x3","x4","x5"]},{"id":"outputs","label":"Statistics","fields":["sum","mean","minVal","maxVal","range"]}],"formulas":{"mean":"(x1+x2+x3+x4+x5)/5","minVal":"min(x1,x2,x3,x4,x5)","maxVal":"max(x1,x2,x3,x4,x5)","range":"max(x1,x2,x3,x4,x5)-min(x1,x2,x3,x4,x5)","sum":"x1+x2+x3+x4+x5"},"examples":[{"label":"[4, 7, 13, 7, 3]","inputs":{"x1":4,"x2":7,"x3":13,"x4":7,"x5":3}},{"label":"Test scores","inputs":{"x1":85,"x2":90,"x3":78,"x4":92,"x5":88}}]}
