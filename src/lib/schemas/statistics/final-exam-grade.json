{"id":"final-exam-grade","slug":"final-exam-grade","name":"Final Exam Grade Calculator","category":"statistics","icon":"📝","description":"Calculate the minimum final exam score needed to achieve your target course grade.","tags":["final exam","grade","GPA","education","statistics"],"fields":[{"id":"currentGrade","label":"Current Grade (%)","type":"number","defaultValue":78,"constraint":{"min":0,"max":100,"step":0.1}},{"id":"finalWeight","label":"Final Exam Weight (%)","type":"number","defaultValue":30,"constraint":{"min":1,"max":100,"step":1}},{"id":"targetGrade","label":"Target Grade (%)","type":"number","defaultValue":80,"constraint":{"min":0,"max":100,"step":0.1}},{"id":"requiredScore","label":"Required Final Score (%)","type":"computed","precision":2,"helpText":"Minimum score needed on final"},{"id":"currentWeight","label":"Current Assignments Weight (%)","type":"computed","precision":0},{"id":"currentContrib","label":"Current Grade Contribution","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"Grade Info","fields":["currentGrade","finalWeight","targetGrade"]},{"id":"outputs","label":"Required Score","fields":["requiredScore","currentWeight","currentContrib"]}],"formulas":{"currentWeight":"100 - finalWeight","currentContrib":"currentGrade * (100 - finalWeight) / 100","requiredScore":"(targetGrade - currentGrade * (100 - finalWeight) / 100) / (finalWeight / 100)"},"examples":[{"label":"78% current, 30% final, target 80%","inputs":{"currentGrade":78,"finalWeight":30,"targetGrade":80}},{"label":"Need a B (85%) with 40% final","inputs":{"currentGrade":82,"finalWeight":40,"targetGrade":85}}]}
