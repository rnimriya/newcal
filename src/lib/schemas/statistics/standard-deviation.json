{
  "id": "standard-deviation-calculator",
  "slug": "standard-deviation-calculator",
  "name": "Standard Deviation Calculator",
  "category": "statistics",
  "icon": "σ",
  "description": "Calculate population and sample standard deviation for up to 8 data values.",
  "tags": [
    "standard deviation",
    "variance",
    "statistics",
    "sigma"
  ],
  "fields": [
    {
      "id": "x1",
      "label": "Value 1",
      "type": "number",
      "defaultValue": 4
    },
    {
      "id": "x2",
      "label": "Value 2",
      "type": "number",
      "defaultValue": 7
    },
    {
      "id": "x3",
      "label": "Value 3",
      "type": "number",
      "defaultValue": 13
    },
    {
      "id": "x4",
      "label": "Value 4",
      "type": "number",
      "defaultValue": 16
    },
    {
      "id": "x5",
      "label": "Value 5",
      "type": "number",
      "defaultValue": 21
    },
    {
      "id": "n",
      "label": "Count (n)",
      "type": "number",
      "defaultValue": 5,
      "constraint": {
        "min": 2,
        "max": 8,
        "step": 1
      }
    },
    {
      "id": "mean",
      "label": "Mean (x̄)",
      "type": "computed",
      "precision": 4
    },
    {
      "id": "variance",
      "label": "Population Variance (σ²)",
      "type": "computed",
      "precision": 4
    },
    {
      "id": "popSD",
      "label": "Population SD (σ)",
      "type": "computed",
      "precision": 4
    },
    {
      "id": "sampleSD",
      "label": "Sample SD (s)",
      "type": "computed",
      "precision": 4
    }
  ],
  "groups": [
    {
      "id": "inputs",
      "label": "Data (up to 5 values)",
      "fields": [
        "x1",
        "x2",
        "x3",
        "x4",
        "x5",
        "n"
      ]
    },
    {
      "id": "outputs",
      "label": "Statistics",
      "fields": [
        "mean",
        "variance",
        "popSD",
        "sampleSD"
      ]
    }
  ],
  "formulas": {
    "mean": "(x1+x2+x3+x4+x5)/n",
    "variance": "((x1-(x1+x2+x3+x4+x5)/n)^2 + (x2-(x1+x2+x3+x4+x5)/n)^2 + (x3-(x1+x2+x3+x4+x5)/n)^2 + (x4-(x1+x2+x3+x4+x5)/n)^2 + (x5-(x1+x2+x3+x4+x5)/n)^2) / n",
    "popSD": "sqrt(((x1-(x1+x2+x3+x4+x5)/n)^2 + (x2-(x1+x2+x3+x4+x5)/n)^2 + (x3-(x1+x2+x3+x4+x5)/n)^2 + (x4-(x1+x2+x3+x4+x5)/n)^2 + (x5-(x1+x2+x3+x4+x5)/n)^2) / n)",
    "sampleSD": "sqrt(((x1-(x1+x2+x3+x4+x5)/n)^2 + (x2-(x1+x2+x3+x4+x5)/n)^2 + (x3-(x1+x2+x3+x4+x5)/n)^2 + (x4-(x1+x2+x3+x4+x5)/n)^2 + (x5-(x1+x2+x3+x4+x5)/n)^2) / (n-1))"
  },
  "examples": [
    {
      "label": "[4, 7, 13, 16, 21]",
      "inputs": {
        "x1": 4,
        "x2": 7,
        "x3": 13,
        "x4": 16,
        "x5": 21,
        "n": 5
      }
    },
    {
      "label": "[2, 4, 4, 4, 5, 5, 7, 9] → use n=8 with 3 extra",
      "inputs": {
        "x1": 2,
        "x2": 4,
        "x3": 4,
        "x4": 4,
        "x5": 5,
        "n": 5
      }
    }
  ]
}