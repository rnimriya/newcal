{"id":"sample-size","slug":"sample-size-calculator","name":"Sample Size Calculator","category":"statistics","icon":"n","description":"Calculate the sample size needed for a given confidence level and margin of error.","tags":["sample size","statistics","survey","confidence interval"],"fields":[{"id":"zStar","label":"Z* (1.96 for 95%, 2.576 for 99%)","type":"number","defaultValue":1.96,"constraint":{"min":0.1,"step":0.01}},{"id":"sdEstimate","label":"Population SD Estimate (σ)","type":"number","defaultValue":0.5,"constraint":{"min":0.001,"step":0.01}},{"id":"marginOfError","label":"Margin of Error (E)","type":"number","defaultValue":0.05,"constraint":{"min":0.001,"step":0.001}},{"id":"n","label":"Required Sample Size (n)","type":"computed","precision":0,"helpText":"Rounded up"},{"id":"nExact","label":"Exact n","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Requirements","fields":["zStar","sdEstimate","marginOfError"]},{"id":"outputs","label":"Sample Size","fields":["n","nExact"]}],"formulas":{"nExact":"(zStar * sdEstimate / marginOfError)^2","n":"ceil((zStar * sdEstimate / marginOfError)^2)"},"examples":[{"label":"95% CI, SD=0.5, E=0.05","inputs":{"zStar":1.96,"sdEstimate":0.5,"marginOfError":0.05}},{"label":"99% CI, SD=15, E=3","inputs":{"zStar":2.576,"sdEstimate":15,"marginOfError":3}}]}
