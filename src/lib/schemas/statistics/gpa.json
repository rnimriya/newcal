{"id":"gpa","slug":"gpa-calculator","name":"GPA Calculator","category":"statistics","icon":"🎓","description":"Calculate your Grade Point Average (GPA) from up to 5 courses with letter grades and credit hours.","tags":["GPA","grade point average","statistics","education"],"fields":[{"id":"grade1","label":"Grade 1 (0-4)","type":"number","defaultValue":4.0,"constraint":{"min":0,"max":4,"step":0.1}},{"id":"credit1","label":"Credits 1","type":"number","defaultValue":3,"constraint":{"min":0,"max":6,"step":1}},{"id":"grade2","label":"Grade 2 (0-4)","type":"number","defaultValue":3.7,"constraint":{"min":0,"max":4,"step":0.1}},{"id":"credit2","label":"Credits 2","type":"number","defaultValue":3},{"id":"grade3","label":"Grade 3 (0-4)","type":"number","defaultValue":3.0,"constraint":{"min":0,"max":4,"step":0.1}},{"id":"credit3","label":"Credits 3","type":"number","defaultValue":4},{"id":"totalGPA","label":"GPA","type":"computed","precision":3},{"id":"totalCredits","label":"Total Credits","type":"computed","precision":0},{"id":"totalPoints","label":"Total Quality Points","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"Courses","fields":["grade1","credit1","grade2","credit2","grade3","credit3"]},{"id":"outputs","label":"GPA","fields":["totalGPA","totalCredits","totalPoints"]}],"formulas":{"totalPoints":"grade1*credit1 + grade2*credit2 + grade3*credit3","totalCredits":"credit1 + credit2 + credit3","totalGPA":"(grade1*credit1 + grade2*credit2 + grade3*credit3) / (credit1 + credit2 + credit3)"},"examples":[{"label":"A, A-, B+","inputs":{"grade1":4.0,"credit1":3,"grade2":3.7,"credit2":3,"grade3":3.3,"credit3":4}},{"label":"All A's","inputs":{"grade1":4.0,"credit1":3,"grade2":4.0,"credit2":3,"grade3":4.0,"credit3":4}}]}
