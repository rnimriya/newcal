{"id":"confidence-interval","slug":"confidence-interval","name":"Confidence Interval Calculator","category":"statistics","icon":"📐","description":"Calculate a confidence interval for a population mean. Enter sample mean, SD, and sample size.","tags":["confidence interval","statistics","sample","z-score"],"fields":[{"id":"sampleMean","label":"Sample Mean (x̄)","type":"number","defaultValue":50},{"id":"sampleSD","label":"Sample Standard Deviation (s)","type":"number","defaultValue":10,"constraint":{"min":0.001}},{"id":"n","label":"Sample Size (n)","type":"number","defaultValue":30,"constraint":{"min":2,"step":1}},{"id":"zStar","label":"Z* (1.96 for 95%)","type":"number","defaultValue":1.96,"constraint":{"min":0.1,"step":0.01}},{"id":"marginOfError","label":"Margin of Error","type":"computed","precision":4},{"id":"lower","label":"Lower Bound","type":"computed","precision":4},{"id":"upper","label":"Upper Bound","type":"computed","precision":4},{"id":"width","label":"Interval Width","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Sample Data","fields":["sampleMean","sampleSD","n","zStar"]},{"id":"outputs","label":"Confidence Interval","fields":["marginOfError","lower","upper","width"]}],"formulas":{"marginOfError":"zStar * sampleSD / sqrt(n)","lower":"sampleMean - zStar * sampleSD / sqrt(n)","upper":"sampleMean + zStar * sampleSD / sqrt(n)","width":"2 * zStar * sampleSD / sqrt(n)"},"examples":[{"label":"95% CI: mean=50, SD=10, n=30","inputs":{"sampleMean":50,"sampleSD":10,"n":30,"zStar":1.96}},{"label":"99% CI: mean=100, SD=15, n=50","inputs":{"sampleMean":100,"sampleSD":15,"n":50,"zStar":2.576}}]}
