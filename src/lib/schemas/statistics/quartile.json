{"id":"quartile","slug":"quartile-calculator","name":"Quartile Calculator","category":"statistics","icon":"Q","description":"Calculate Q1, Q2 (median), Q3, and the Interquartile Range (IQR) from a 5-value dataset.","tags":["quartile","IQR","statistics","Q1","Q3"],"fields":[{"id":"x1","label":"Value 1 (smallest)","type":"number","defaultValue":1},{"id":"x2","label":"Value 2","type":"number","defaultValue":3},{"id":"x3","label":"Value 3 (median)","type":"number","defaultValue":5},{"id":"x4","label":"Value 4","type":"number","defaultValue":7},{"id":"x5","label":"Value 5 (largest)","type":"number","defaultValue":9},{"id":"q1","label":"Q1 (25th percentile)","type":"computed","precision":4,"helpText":"Median of lower half"},{"id":"q2","label":"Q2 (Median)","type":"computed","precision":4},{"id":"q3","label":"Q3 (75th percentile)","type":"computed","precision":4},{"id":"iqr","label":"IQR = Q3 - Q1","type":"computed","precision":4},{"id":"lowerFence","label":"Lower Fence (Q1 - 1.5×IQR)","type":"computed","precision":4},{"id":"upperFence","label":"Upper Fence (Q3 + 1.5×IQR)","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Sorted Data (5 values)","fields":["x1","x2","x3","x4","x5"]},{"id":"outputs","label":"Quartiles","fields":["q1","q2","q3","iqr","lowerFence","upperFence"]}],"formulas":{"q1":"(x1+x2)/2","q2":"x3","q3":"(x4+x5)/2","iqr":"(x4+x5)/2 - (x1+x2)/2","lowerFence":"(x1+x2)/2 - 1.5*((x4+x5)/2 - (x1+x2)/2)","upperFence":"(x4+x5)/2 + 1.5*((x4+x5)/2 - (x1+x2)/2)"},"examples":[{"label":"[1, 3, 5, 7, 9]","inputs":{"x1":1,"x2":3,"x3":5,"x4":7,"x5":9}},{"label":"Test data","inputs":{"x1":10,"x2":25,"x3":35,"x4":45,"x5":80}}]}
