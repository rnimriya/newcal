{"id":"vote-percentage","slug":"vote-percentage","name":"Vote Percentage Calculator","category":"statistics","icon":"🗳️","description":"Calculate vote percentages and margins for any election or poll with up to 4 candidates.","tags":["vote percentage","election","poll","statistics"],"fields":[{"id":"v1","label":"Candidate 1 Votes","type":"number","defaultValue":5400,"constraint":{"min":0,"step":1}},{"id":"v2","label":"Candidate 2 Votes","type":"number","defaultValue":3200,"constraint":{"min":0,"step":1}},{"id":"v3","label":"Candidate 3 Votes","type":"number","defaultValue":800,"constraint":{"min":0,"step":1}},{"id":"v4","label":"Candidate 4 Votes","type":"number","defaultValue":600,"constraint":{"min":0,"step":1}},{"id":"total","label":"Total Votes","type":"computed","precision":0},{"id":"pct1","label":"Candidate 1 (%)","type":"computed","precision":2},{"id":"pct2","label":"Candidate 2 (%)","type":"computed","precision":2},{"id":"pct3","label":"Candidate 3 (%)","type":"computed","precision":2},{"id":"margin","label":"Win Margin (%)","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"Vote Counts","fields":["v1","v2","v3","v4"]},{"id":"outputs","label":"Percentages","fields":["total","pct1","pct2","pct3","margin"]}],"formulas":{"total":"v1+v2+v3+v4","pct1":"v1/(v1+v2+v3+v4)*100","pct2":"v2/(v1+v2+v3+v4)*100","pct3":"v3/(v1+v2+v3+v4)*100","margin":"(v1-v2)/(v1+v2+v3+v4)*100"},"examples":[{"label":"Local election","inputs":{"v1":5400,"v2":3200,"v3":800,"v4":600}},{"label":"Class poll","inputs":{"v1":18,"v2":12,"v3":5,"v4":0}}]}
