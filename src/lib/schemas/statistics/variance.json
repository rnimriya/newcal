{"id":"variance","slug":"variance-calculator","name":"Variance Calculator","category":"statistics","icon":"σ²","description":"Calculate population variance and sample variance for up to 5 data values.","tags":["variance","statistics","spread","standard deviation"],"fields":[{"id":"x1","label":"Value 1","type":"number","defaultValue":2},{"id":"x2","label":"Value 2","type":"number","defaultValue":4},{"id":"x3","label":"Value 3","type":"number","defaultValue":4},{"id":"x4","label":"Value 4","type":"number","defaultValue":4},{"id":"x5","label":"Value 5","type":"number","defaultValue":5},{"id":"mean","label":"Mean","type":"computed","precision":4},{"id":"popVariance","label":"Population Variance (σ²)","type":"computed","precision":6},{"id":"sampleVariance","label":"Sample Variance (s²)","type":"computed","precision":6}],"groups":[{"id":"inputs","label":"Data Values","fields":["x1","x2","x3","x4","x5"]},{"id":"outputs","label":"Variance","fields":["mean","popVariance","sampleVariance"]}],"formulas":{"mean":"(x1+x2+x3+x4+x5)/5","popVariance":"((x1-(x1+x2+x3+x4+x5)/5)^2+(x2-(x1+x2+x3+x4+x5)/5)^2+(x3-(x1+x2+x3+x4+x5)/5)^2+(x4-(x1+x2+x3+x4+x5)/5)^2+(x5-(x1+x2+x3+x4+x5)/5)^2)/5","sampleVariance":"((x1-(x1+x2+x3+x4+x5)/5)^2+(x2-(x1+x2+x3+x4+x5)/5)^2+(x3-(x1+x2+x3+x4+x5)/5)^2+(x4-(x1+x2+x3+x4+x5)/5)^2+(x5-(x1+x2+x3+x4+x5)/5)^2)/4"},"examples":[{"label":"[2, 4, 4, 4, 5]","inputs":{"x1":2,"x2":4,"x3":4,"x4":4,"x5":5}},{"label":"[10, 20, 30, 40, 50]","inputs":{"x1":10,"x2":20,"x3":30,"x4":40,"x5":50}}]}
