{"id":"age-checker","slug":"age-checker","name":"Age Checker","category":"time","icon":"✓","description":"Check if someone meets a minimum age requirement based on their birth year.","tags":["age checker","minimum age","time","verify"],"fields":[{"id":"birthYear","label":"Birth Year","type":"number","defaultValue":2000,"constraint":{"min":1900,"max":2024,"step":1}},{"id":"currentYear","label":"Current Year","type":"number","defaultValue":2026,"constraint":{"min":2000,"max":2100,"step":1}},{"id":"requiredAge","label":"Required Minimum Age","type":"number","defaultValue":18,"constraint":{"min":1,"max":100,"step":1}},{"id":"currentAge","label":"Current Age (approx)","type":"computed","precision":0},{"id":"yearsUntilRequired","label":"Years Until Required Age","type":"computed","precision":0,"helpText":"0 if already meets requirement"},{"id":"ageAtRequired","label":"Year They Turn Required Age","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Details","fields":["birthYear","currentYear","requiredAge"]},{"id":"outputs","label":"Check","fields":["currentAge","yearsUntilRequired","ageAtRequired"]}],"formulas":{"currentAge":"currentYear - birthYear","yearsUntilRequired":"max(0, requiredAge - (currentYear - birthYear))","ageAtRequired":"birthYear + requiredAge"},"examples":[{"label":"Born 2000, checking for age 18","inputs":{"birthYear":2000,"currentYear":2026,"requiredAge":18}},{"label":"Born 2010, checking for age 21","inputs":{"birthYear":2010,"currentYear":2026,"requiredAge":21}}]}
