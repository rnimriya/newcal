{"id":"gross-pay","slug":"gross-pay-calculator","name":"Gross Pay Calculator","category":"time","icon":"💵","description":"Calculate gross pay from regular hours, overtime hours, and hourly rate.","tags":["gross pay","payroll","overtime","salary","time"],"fields":[{"id":"regularHours","label":"Regular Hours","type":"number","defaultValue":40,"constraint":{"min":0,"max":80,"step":0.5}},{"id":"otHours","label":"Overtime Hours","type":"number","defaultValue":5,"constraint":{"min":0,"step":0.5}},{"id":"hourlyRate","label":"Hourly Rate ($)","type":"number","defaultValue":18,"constraint":{"min":0,"step":0.01}},{"id":"otMultiplier","label":"OT Multiplier","type":"number","defaultValue":1.5,"constraint":{"min":1,"max":3,"step":0.25}},{"id":"regularPay","label":"Regular Pay ($)","type":"computed","precision":2},{"id":"otPay","label":"Overtime Pay ($)","type":"computed","precision":2},{"id":"grossPay","label":"Gross Pay ($)","type":"computed","precision":2},{"id":"effectiveRate","label":"Effective Hourly Rate ($)","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Hours & Rate","fields":["regularHours","otHours","hourlyRate","otMultiplier"]},{"id":"outputs","label":"Pay","fields":["regularPay","otPay","grossPay","effectiveRate"]}],"formulas":{"regularPay":"regularHours * hourlyRate","otPay":"otHours * hourlyRate * otMultiplier","grossPay":"regularHours * hourlyRate + otHours * hourlyRate * otMultiplier","effectiveRate":"(regularHours * hourlyRate + otHours * hourlyRate * otMultiplier) / (regularHours + otHours)"},"examples":[{"label":"40 regular + 5 OT at $18/hr","inputs":{"regularHours":40,"otHours":5,"hourlyRate":18,"otMultiplier":1.5}},{"label":"Part-time 25 hrs, no OT","inputs":{"regularHours":25,"otHours":0,"hourlyRate":15,"otMultiplier":1.5}}]}
