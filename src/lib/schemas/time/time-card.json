{"id":"time-card","slug":"time-card-calculator","name":"Time Card Calculator","category":"time","icon":"⏱️","description":"Calculate total hours worked from daily time card entries across a 5-day work week.","tags":["time card","hours worked","payroll","time","weekly"],"fields":[{"id":"mon","label":"Monday (hours)","type":"number","defaultValue":8,"constraint":{"min":0,"max":24,"step":0.5}},{"id":"tue","label":"Tuesday (hours)","type":"number","defaultValue":8.5},{"id":"wed","label":"Wednesday (hours)","type":"number","defaultValue":8},{"id":"thu","label":"Thursday (hours)","type":"number","defaultValue":9},{"id":"fri","label":"Friday (hours)","type":"number","defaultValue":7.5},{"id":"hourlyRate","label":"Hourly Rate ($)","type":"number","defaultValue":20,"constraint":{"min":0,"step":0.01}},{"id":"totalHours","label":"Total Hours","type":"computed","precision":2},{"id":"regularPay","label":"Regular Pay ($)","type":"computed","precision":2},{"id":"otHours","label":"Overtime Hours (over 40)","type":"computed","precision":2},{"id":"grossPay","label":"Gross Pay ($)","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"Daily Hours","fields":["mon","tue","wed","thu","fri","hourlyRate"]},{"id":"outputs","label":"Totals","fields":["totalHours","regularPay","otHours","grossPay"]}],"formulas":{"totalHours":"mon+tue+wed+thu+fri","regularPay":"min(mon+tue+wed+thu+fri,40)*hourlyRate","otHours":"max(0, mon+tue+wed+thu+fri-40)","grossPay":"min(mon+tue+wed+thu+fri,40)*hourlyRate + max(0, mon+tue+wed+thu+fri-40)*hourlyRate*1.5"},"examples":[{"label":"Standard week at $20/hr","inputs":{"mon":8,"tue":8.5,"wed":8,"thu":9,"fri":7.5,"hourlyRate":20}},{"label":"Overtime week","inputs":{"mon":10,"tue":10,"wed":10,"thu":10,"fri":10,"hourlyRate":25}}]}
