{"id":"hours-calculator","slug":"hours-calculator","name":"Hours Calculator","category":"time","icon":"⏰","description":"Calculate total hours between start and end time. Supports breaks and multiple days.","tags":["hours","time","calculator","work hours"],"fields":[{"id":"startHour","label":"Start Hour (0-23)","type":"number","defaultValue":9,"constraint":{"min":0,"max":23,"step":1}},{"id":"startMin","label":"Start Minute (0-59)","type":"number","defaultValue":0,"constraint":{"min":0,"max":59,"step":1}},{"id":"endHour","label":"End Hour (0-23)","type":"number","defaultValue":17,"constraint":{"min":0,"max":23,"step":1}},{"id":"endMin","label":"End Minute (0-59)","type":"number","defaultValue":30,"constraint":{"min":0,"max":59,"step":1}},{"id":"breakMin","label":"Break Time (minutes)","type":"number","defaultValue":30,"constraint":{"min":0,"step":1}},{"id":"totalMin","label":"Total Minutes (with break)","type":"computed","precision":0},{"id":"totalHours","label":"Total Hours","type":"computed","precision":4},{"id":"netHours","label":"Net Hours (after break)","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Work Period","fields":["startHour","startMin","endHour","endMin","breakMin"]},{"id":"outputs","label":"Results","fields":["totalMin","totalHours","netHours"]}],"formulas":{"totalMin":"(endHour * 60 + endMin) - (startHour * 60 + startMin)","totalHours":"((endHour * 60 + endMin) - (startHour * 60 + startMin)) / 60","netHours":"((endHour * 60 + endMin) - (startHour * 60 + startMin) - breakMin) / 60"},"examples":[{"label":"9 AM to 5:30 PM, 30 min break","inputs":{"startHour":9,"startMin":0,"endHour":17,"endMin":30,"breakMin":30}},{"label":"8 AM to 4 PM, 1 hour break","inputs":{"startHour":8,"startMin":0,"endHour":16,"endMin":0,"breakMin":60}}]}
