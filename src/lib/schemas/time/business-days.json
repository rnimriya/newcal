{"id":"business-days","slug":"business-days","name":"Business Days Calculator","category":"time","icon":"💼","description":"Calculate business days from total calendar days, excluding weekends. Estimate working days for project planning.","tags":["business days","working days","weekdays","time","calculator"],"fields":[{"id":"calendarDays","label":"Total Calendar Days","type":"number","defaultValue":30,"constraint":{"min":1,"step":1}},{"id":"holidays","label":"Public Holidays to Exclude","type":"number","defaultValue":2,"constraint":{"min":0,"step":1}},{"id":"businessDays","label":"Business Days","type":"computed","precision":0,"helpText":"≈ 5/7 of calendar days"},{"id":"weekendDays","label":"Weekend Days","type":"computed","precision":0},{"id":"netBusinessDays","label":"Net Business Days (after holidays)","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Period","fields":["calendarDays","holidays"]},{"id":"outputs","label":"Results","fields":["businessDays","weekendDays","netBusinessDays"]}],"formulas":{"businessDays":"floor(calendarDays * 5 / 7)","weekendDays":"calendarDays - floor(calendarDays * 5 / 7)","netBusinessDays":"floor(calendarDays * 5 / 7) - holidays"},"examples":[{"label":"30 calendar days, 2 holidays","inputs":{"calendarDays":30,"holidays":2}},{"label":"90 day project","inputs":{"calendarDays":90,"holidays":5}}]}
