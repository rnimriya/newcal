{"id":"time-hms","slug":"time-calculator-hms","name":"Time Calculator H:M:S","category":"time","icon":"⏱️","description":"Add or subtract time in hours, minutes, and seconds. Convert between time units.","tags":["hours minutes seconds","time calculator","HH:MM:SS","time"],"fields":[{"id":"h1","label":"Hours (first time)","type":"number","defaultValue":2,"constraint":{"min":0,"step":1}},{"id":"m1","label":"Minutes (first time)","type":"number","defaultValue":30,"constraint":{"min":0,"max":59,"step":1}},{"id":"s1","label":"Seconds (first time)","type":"number","defaultValue":45,"constraint":{"min":0,"max":59,"step":1}},{"id":"h2","label":"Hours (second time)","type":"number","defaultValue":1,"constraint":{"min":0,"step":1}},{"id":"m2","label":"Minutes (second time)","type":"number","defaultValue":45,"constraint":{"min":0,"max":59,"step":1}},{"id":"s2","label":"Seconds (second time)","type":"number","defaultValue":30,"constraint":{"min":0,"max":59,"step":1}},{"id":"totalSeconds","label":"Sum (total seconds)","type":"computed","precision":0},{"id":"totalHours","label":"Sum (decimal hours)","type":"computed","precision":6},{"id":"sumH","label":"Sum (hours part)","type":"computed","precision":0},{"id":"sumM","label":"Sum (minutes part)","type":"computed","precision":0}],"groups":[{"id":"time1","label":"First Time","fields":["h1","m1","s1"]},{"id":"time2","label":"Second Time","fields":["h2","m2","s2"]},{"id":"outputs","label":"Sum","fields":["totalSeconds","totalHours","sumH","sumM"]}],"formulas":{"totalSeconds":"h1*3600+m1*60+s1 + h2*3600+m2*60+s2","totalHours":"(h1*3600+m1*60+s1 + h2*3600+m2*60+s2)/3600","sumH":"floor((h1*3600+m1*60+s1 + h2*3600+m2*60+s2)/3600)","sumM":"floor(mod(h1*3600+m1*60+s1 + h2*3600+m2*60+s2, 3600)/60)"},"examples":[{"label":"2:30:45 + 1:45:30","inputs":{"h1":2,"m1":30,"s1":45,"h2":1,"m2":45,"s2":30}},{"label":"0:45:00 + 0:30:00","inputs":{"h1":0,"m1":45,"s1":0,"h2":0,"m2":30,"s2":0}}]}
