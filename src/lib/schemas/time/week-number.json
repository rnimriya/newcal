{"id":"week-number","slug":"week-number","name":"Week Number Calculator","category":"time","icon":"📅","description":"Calculate the week number of any day in the year and how many weeks are in a year.","tags":["week number","ISO week","date","time","calendar"],"fields":[{"id":"dayOfYear","label":"Day of Year (1-366)","type":"number","defaultValue":150,"constraint":{"min":1,"max":366,"step":1}},{"id":"isLeapYear","label":"Leap Year? (1=yes, 0=no)","type":"number","defaultValue":0,"constraint":{"min":0,"max":1,"step":1}},{"id":"weekNumber","label":"Week Number","type":"computed","precision":0,"helpText":"Day of year ÷ 7, rounded up"},{"id":"daysInYear","label":"Days in Year","type":"computed","precision":0},{"id":"weeksInYear","label":"Weeks in Year","type":"computed","precision":2},{"id":"dayOfWeek","label":"Approx Day of Week (1=Mon)","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Day","fields":["dayOfYear","isLeapYear"]},{"id":"outputs","label":"Week Info","fields":["weekNumber","daysInYear","weeksInYear","dayOfWeek"]}],"formulas":{"weekNumber":"ceil(dayOfYear/7)","daysInYear":"isLeapYear > 0 ? 366 : 365","weeksInYear":"(isLeapYear > 0 ? 366 : 365) / 7","dayOfWeek":"mod(dayOfYear - 1, 7) + 1"},"examples":[{"label":"Day 150 (May 30, non-leap)","inputs":{"dayOfYear":150,"isLeapYear":0}},{"label":"Day 1 (Jan 1)","inputs":{"dayOfYear":1,"isLeapYear":0}}]}
