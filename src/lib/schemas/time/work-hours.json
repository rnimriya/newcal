{
  "id": "work-hours-calculator",
  "slug": "work-hours-calculator",
  "name": "Work Hours Calculator",
  "category": "time",
  "icon": "💼",
  "description": "Calculate weekly work hours, annual hours, and pay based on hourly rate.",
  "tags": [
    "work hours",
    "pay",
    "salary",
    "time",
    "calculator"
  ],
  "fields": [
    {
      "id": "hoursPerDay",
      "label": "Hours per Day",
      "type": "number",
      "defaultValue": 8,
      "constraint": {
        "min": 0,
        "max": 24,
        "step": 0.5
      }
    },
    {
      "id": "daysPerWeek",
      "label": "Days per Week",
      "type": "number",
      "defaultValue": 5,
      "constraint": {
        "min": 1,
        "max": 7,
        "step": 1
      }
    },
    {
      "id": "hourlyRate",
      "label": "Hourly Rate ($)",
      "type": "number",
      "defaultValue": 25,
      "constraint": {
        "min": 0,
        "step": 0.01
      }
    },
    {
      "id": "weeklyHours",
      "label": "Weekly Hours",
      "type": "computed",
      "precision": 1
    },
    {
      "id": "monthlyHours",
      "label": "Monthly Hours (avg)",
      "type": "computed",
      "precision": 1
    },
    {
      "id": "annualHours",
      "label": "Annual Hours",
      "type": "computed",
      "precision": 0
    },
    {
      "id": "weeklyPay",
      "label": "Weekly Pay ($)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "annualPay",
      "label": "Annual Pay ($)",
      "type": "computed",
      "precision": 2
    }
  ],
  "groups": [
    {
      "id": "inputs",
      "label": "Work Schedule",
      "fields": [
        "hoursPerDay",
        "daysPerWeek",
        "hourlyRate"
      ]
    },
    {
      "id": "outputs",
      "label": "Totals",
      "fields": [
        "weeklyHours",
        "monthlyHours",
        "annualHours",
        "weeklyPay",
        "annualPay"
      ]
    }
  ],
  "formulas": {
    "weeklyHours": "hoursPerDay * daysPerWeek",
    "monthlyHours": "hoursPerDay * daysPerWeek * 52 / 12",
    "annualHours": "hoursPerDay * daysPerWeek * 52",
    "weeklyPay": "hoursPerDay * daysPerWeek * hourlyRate",
    "annualPay": "hoursPerDay * daysPerWeek * 52 * hourlyRate"
  },
  "examples": [
    {
      "label": "Standard 8hr/5day at $25/hr",
      "inputs": {
        "hoursPerDay": 8,
        "daysPerWeek": 5,
        "hourlyRate": 25
      }
    },
    {
      "label": "Part-time 4hr/3day",
      "inputs": {
        "hoursPerDay": 4,
        "daysPerWeek": 3,
        "hourlyRate": 15
      }
    }
  ]
}