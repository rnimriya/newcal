{"id":"age-calculator","slug":"age-calculator","name":"Age Calculator","category":"time","icon":"🎂","description":"Calculate your exact age in years, months, days, hours, and minutes from your birth year.","tags":["age calculator","birthday","age","time"],"fields":[{"id":"birthYear","label":"Birth Year","type":"number","defaultValue":1990,"constraint":{"min":1900,"max":2025,"step":1}},{"id":"currentYear","label":"Current Year","type":"number","defaultValue":2026,"constraint":{"min":1900,"max":2100,"step":1}},{"id":"ageYears","label":"Age (years)","type":"computed","precision":0},{"id":"ageMonths","label":"Age (months)","type":"computed","precision":0},{"id":"ageDays","label":"Age (days, approx)","type":"computed","precision":0},{"id":"ageHours","label":"Age (hours, approx)","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Years","fields":["birthYear","currentYear"]},{"id":"outputs","label":"Age","fields":["ageYears","ageMonths","ageDays","ageHours"]}],"formulas":{"ageYears":"currentYear - birthYear","ageMonths":"(currentYear - birthYear) * 12","ageDays":"(currentYear - birthYear) * 365","ageHours":"(currentYear - birthYear) * 365 * 24"},"examples":[{"label":"Born 1990","inputs":{"birthYear":1990,"currentYear":2026}},{"label":"Born 2000","inputs":{"birthYear":2000,"currentYear":2026}}]}
