{"id":"decimal-to-time","slug":"decimal-to-time","name":"Decimal to Time Converter","category":"time","icon":"⏱️","description":"Convert decimal hours back to hours, minutes, and seconds format.","tags":["decimal to time","hours","minutes","time","converter"],"fields":[{"id":"decimal","label":"Decimal Hours","type":"number","defaultValue":7.75,"constraint":{"min":0,"step":0.01}},{"id":"hours","label":"Hours","type":"computed","precision":0},{"id":"minutes","label":"Minutes","type":"computed","precision":0},{"id":"seconds","label":"Seconds","type":"computed","precision":0},{"id":"totalSeconds","label":"Total Seconds","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Decimal Hours","fields":["decimal"]},{"id":"outputs","label":"Time","fields":["hours","minutes","seconds","totalSeconds"]}],"formulas":{"hours":"floor(decimal)","minutes":"floor((decimal - floor(decimal)) * 60)","seconds":"round(((decimal - floor(decimal)) * 60 - floor((decimal - floor(decimal)) * 60)) * 60)","totalSeconds":"round(decimal * 3600)"},"examples":[{"label":"7.75 hours","inputs":{"decimal":7.75}},{"label":"1.5 hours","inputs":{"decimal":1.5}}]}
