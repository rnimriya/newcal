{"id":"markup","slug":"markup-calculator","name":"Markup Calculator","category":"finance","icon":"📊","description":"Calculate selling price from cost and markup percentage. Find margin and profit.","tags":["markup","margin","profit","pricing","finance"],"fields":[{"id":"cost","label":"Cost ($)","type":"number","defaultValue":50,"constraint":{"min":0,"step":0.01}},{"id":"markupPct","label":"Markup (%)","type":"number","defaultValue":60,"constraint":{"min":0,"step":0.1}},{"id":"sellingPrice","label":"Selling Price ($)","type":"computed","precision":2},{"id":"profit","label":"Profit ($)","type":"computed","precision":2},{"id":"marginPct","label":"Gross Margin (%)","type":"computed","precision":4,"helpText":"Profit / Selling Price × 100"}],"groups":[{"id":"inputs","label":"Cost & Markup","fields":["cost","markupPct"]},{"id":"outputs","label":"Pricing","fields":["sellingPrice","profit","marginPct"]}],"formulas":{"sellingPrice":"cost * (1 + markupPct/100)","profit":"cost * markupPct / 100","marginPct":"(cost * markupPct / 100) / (cost * (1 + markupPct/100)) * 100"},"examples":[{"label":"$50 cost, 60% markup","inputs":{"cost":50,"markupPct":60}},{"label":"$100 cost, 50% markup","inputs":{"cost":100,"markupPct":50}}]}
