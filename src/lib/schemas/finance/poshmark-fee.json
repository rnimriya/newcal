{"id":"poshmark-fee","slug":"poshmark-fee-calculator","name":"Poshmark Fee Calculator","category":"finance","icon":"👗","description":"Calculate Poshmark seller fees and your net earnings. Under $15: flat $2.95 fee. $15+: 20% fee.","tags":["poshmark","fee","selling","resale","finance"],"fields":[{"id":"salePrice","label":"Sale Price ($)","type":"number","defaultValue":35,"constraint":{"min":0.01,"step":0.01}},{"id":"fee","label":"Poshmark Fee ($)","type":"computed","precision":2,"helpText":"$2.95 if < $15, else 20%"},{"id":"netEarnings","label":"Your Earnings ($)","type":"computed","precision":2},{"id":"feePct","label":"Effective Fee (%)","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"Sale","fields":["salePrice"]},{"id":"outputs","label":"Breakdown","fields":["fee","netEarnings","feePct"]}],"formulas":{"fee":"salePrice < 15 ? 2.95 : salePrice * 0.20","netEarnings":"salePrice < 15 ? salePrice - 2.95 : salePrice * 0.80","feePct":"salePrice < 15 ? 2.95/salePrice*100 : 20"},"examples":[{"label":"$35 item (20% fee)","inputs":{"salePrice":35}},{"label":"$12 item (flat $2.95)","inputs":{"salePrice":12}},{"label":"$100 item (20% fee)","inputs":{"salePrice":100}}]}
