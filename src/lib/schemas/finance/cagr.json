{
  "id": "cagr",
  "slug": "cagr-calculator",
  "name": "CAGR Calculator",
  "category": "finance",
  "icon": "📊",
  "description": "Calculate the Compound Annual Growth Rate (CAGR) of an investment over a period of time.",
  "tags": [
    "cagr",
    "growth rate",
    "returns",
    "investment",
    "finance"
  ],
  "fields": [
    {
      "id": "initialValue",
      "label": "Initial Investment Value (₹)",
      "type": "number",
      "defaultValue": 10000,
      "constraint": {
        "min": 1,
        "step": 100
      }
    },
    {
      "id": "finalValue",
      "label": "Final Investment Value (₹)",
      "type": "number",
      "defaultValue": 25000,
      "constraint": {
        "min": 1,
        "step": 100
      }
    },
    {
      "id": "years",
      "label": "Duration (years)",
      "type": "number",
      "defaultValue": 5,
      "constraint": {
        "min": 0.1,
        "max": 50,
        "step": 0.1
      }
    },
    {
      "id": "cagr",
      "label": "CAGR (% p.a.)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "totalReturn",
      "label": "Total Return (%)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "absoluteGain",
      "label": "Absolute Gain (₹)",
      "type": "computed",
      "precision": 2
    }
  ],
  "groups": [
    {
      "id": "inputs",
      "label": "Details",
      "fields": [
        "initialValue",
        "finalValue",
        "years"
      ]
    },
    {
      "id": "outputs",
      "label": "Outputs",
      "fields": [
        "cagr",
        "totalReturn",
        "absoluteGain"
      ]
    }
  ],
  "formulas": {
    "cagr": "((finalValue / initialValue)^(1 / years) - 1) * 100",
    "totalReturn": "((finalValue - initialValue) / initialValue) * 100",
    "absoluteGain": "finalValue - initialValue"
  },
  "examples": [
    {
      "label": "Example Values",
      "inputs": {
        "initialValue": 10000,
        "finalValue": 25000,
        "years": 5
      }
    }
  ]
}