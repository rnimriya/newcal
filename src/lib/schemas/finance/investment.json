{
  "id": "investment",
  "slug": "investment-calculator",
  "name": "Investment Calculator",
  "category": "finance",
  "icon": "💼",
  "description": "Calculate the future value of an investment with initial principal and monthly additions.",
  "tags": [
    "investment",
    "savings",
    "wealth",
    "compound interest",
    "finance"
  ],
  "fields": [
    {
      "id": "initialInvestment",
      "label": "Initial Principal (₹)",
      "type": "number",
      "defaultValue": 10000,
      "constraint": {
        "min": 0,
        "step": 1000
      }
    },
    {
      "id": "monthlyContribution",
      "label": "Monthly Contribution (₹)",
      "type": "number",
      "defaultValue": 1000,
      "constraint": {
        "min": 0,
        "step": 100
      }
    },
    {
      "id": "expectedReturn",
      "label": "Expected Annual Return (%)",
      "type": "number",
      "defaultValue": 12,
      "constraint": {
        "min": 0.1,
        "max": 50,
        "step": 0.1
      }
    },
    {
      "id": "years",
      "label": "Period (years)",
      "type": "number",
      "defaultValue": 10,
      "constraint": {
        "min": 1,
        "max": 50,
        "step": 1
      }
    },
    {
      "id": "totalInvested",
      "label": "Total Amount Invested (₹)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "maturityAmount",
      "label": "Maturity Amount (₹)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "wealthGain",
      "label": "Wealth Gained (₹)",
      "type": "computed",
      "precision": 2
    }
  ],
  "groups": [
    {
      "id": "inputs",
      "label": "Details",
      "fields": [
        "initialInvestment",
        "monthlyContribution",
        "expectedReturn",
        "years"
      ]
    },
    {
      "id": "outputs",
      "label": "Outputs",
      "fields": [
        "totalInvested",
        "maturityAmount",
        "wealthGain"
      ]
    }
  ],
  "formulas": {
    "totalInvested": "initialInvestment + monthlyContribution * years * 12",
    "maturityAmount": "initialInvestment * (1 + expectedReturn/1200)^(years * 12) + (expectedReturn == 0 ? monthlyContribution * years * 12 : monthlyContribution * ((1 + expectedReturn/1200)^(years * 12) - 1) / (expectedReturn/1200) * (1 + expectedReturn/1200))",
    "wealthGain": "maturityAmount - totalInvested"
  },
  "examples": [
    {
      "label": "Example Values",
      "inputs": {
        "initialInvestment": 10000,
        "monthlyContribution": 1000,
        "expectedReturn": 12,
        "years": 10
      }
    }
  ]
}