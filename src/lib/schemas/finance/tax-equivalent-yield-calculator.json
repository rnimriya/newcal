{
  "id": "tax-equivalent-yield",
  "slug": "tax-equivalent-yield-calculator",
  "name": "Tax-Equivalent Yield Calculator",
  "category": "finance",
  "description": "Calculate the taxable yield needed to equal a tax-exempt municipal bond yield after federal and state taxes.",
  "icon": "🏛️",
  "tags": ["municipal bond", "tax-exempt", "tax equivalent yield", "muni bond", "after-tax return"],
  "fields": [
    { "id": "municipalYield", "label": "Municipal Bond Yield", "type": "number", "defaultValue": 3.5, "suffix": "%", "constraint": { "min": 0.1, "max": 20, "step": 0.1, "required": true } },
    { "id": "federalTaxRate", "label": "Federal Tax Rate", "type": "number", "defaultValue": 24, "suffix": "%", "constraint": { "min": 0, "max": 60, "step": 1, "required": true } },
    { "id": "stateTaxRate", "label": "State Tax Rate", "type": "number", "defaultValue": 5, "suffix": "%", "constraint": { "min": 0, "max": 20, "step": 0.5 } },
    { "id": "combinedTaxRate", "label": "Combined Tax Rate", "type": "computed", "precision": 2, "suffix": "%" },
    { "id": "taxEquivalentYield", "label": "Tax-Equivalent Yield", "type": "computed", "precision": 3, "suffix": "%" },
    { "id": "afterTaxYieldComparison", "label": "After-Tax Yield (TEY equivalent)", "type": "computed", "precision": 3, "suffix": "%" },
    { "id": "breakEvenTaxableYield", "label": "Break-Even Taxable Yield (Federal only)", "type": "computed", "precision": 3, "suffix": "%" }
  ],
  "groups": [
    { "id": "inputs", "label": "Yield & Tax Parameters", "fields": ["municipalYield", "federalTaxRate", "stateTaxRate"] },
    { "id": "outputs", "label": "TEY Analysis", "fields": ["combinedTaxRate", "taxEquivalentYield", "afterTaxYieldComparison", "breakEvenTaxableYield"] }
  ],
  "formulas": {
    "combinedTaxRate": "(1 - (1 - federalTaxRate/100) * (1 - stateTaxRate/100)) * 100",
    "taxEquivalentYield": "municipalYield / (1 - combinedTaxRate/100)",
    "afterTaxYieldComparison": "taxEquivalentYield * (1 - combinedTaxRate/100)",
    "breakEvenTaxableYield": "municipalYield / (1 - federalTaxRate/100)"
  },
  "examples": [
    { "label": "High-income investor", "inputs": { "municipalYield": 3.5, "federalTaxRate": 24, "stateTaxRate": 5 } },
    { "label": "Top bracket", "inputs": { "municipalYield": 4, "federalTaxRate": 37, "stateTaxRate": 9.3 } },
    { "label": "Lower bracket", "inputs": { "municipalYield": 3, "federalTaxRate": 12, "stateTaxRate": 3 } }
  ],
  "explanation": "Municipal bond interest is typically exempt from federal income tax and often state taxes too. The tax-equivalent yield shows what a taxable bond must yield to match the after-tax return of a muni bond. Higher tax brackets benefit more from munis, since the TEY rises with tax rates."
}
