{"id":"commission","slug":"commission-calculator","name":"Commission Calculator","category":"finance","icon":"💰","description":"Calculate sales commission amount and net pay after commission.","tags":["commission","sales","finance","earnings"],"fields":[{"id":"saleAmount","label":"Sale Amount ($)","type":"number","defaultValue":10000,"constraint":{"min":0,"step":0.01}},{"id":"commissionRate","label":"Commission Rate (%)","type":"number","defaultValue":5,"constraint":{"min":0,"max":100,"step":0.1}},{"id":"baseSalary","label":"Base Salary ($)","type":"number","defaultValue":2000,"constraint":{"min":0,"step":0.01}},{"id":"commissionEarned","label":"Commission Earned ($)","type":"computed","precision":2},{"id":"totalPay","label":"Total Pay ($)","type":"computed","precision":2},{"id":"effectiveRate","label":"Total Pay / Sale (%)","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Sale Details","fields":["saleAmount","commissionRate","baseSalary"]},{"id":"outputs","label":"Earnings","fields":["commissionEarned","totalPay","effectiveRate"]}],"formulas":{"commissionEarned":"saleAmount * commissionRate / 100","totalPay":"baseSalary + saleAmount * commissionRate / 100","effectiveRate":"(baseSalary + saleAmount * commissionRate / 100) / saleAmount * 100"},"examples":[{"label":"$10,000 sale at 5% commission","inputs":{"saleAmount":10000,"commissionRate":5,"baseSalary":2000}},{"label":"$50,000 deal at 2%","inputs":{"saleAmount":50000,"commissionRate":2,"baseSalary":3000}}]}
