{"id":"adsense","slug":"adsense-calculator","name":"AdSense Calculator","category":"finance","icon":"💰","description":"Estimate Google AdSense earnings from page views, CTR, and CPC.","tags":["adsense","earnings","monetization","finance"],"fields":[{"id":"dailyPageViews","label":"Daily Page Views","type":"number","defaultValue":10000,"constraint":{"min":1,"step":100}},{"id":"ctr","label":"CTR — Click Through Rate (%)","type":"number","defaultValue":1.5,"constraint":{"min":0.01,"max":100,"step":0.01}},{"id":"cpc","label":"CPC — Cost Per Click ($)","type":"number","defaultValue":0.35,"constraint":{"min":0.001,"step":0.01}},{"id":"dailyClicks","label":"Daily Clicks","type":"computed","precision":0},{"id":"dailyEarnings","label":"Daily Earnings ($)","type":"computed","precision":2},{"id":"monthlyEarnings","label":"Monthly Earnings ($)","type":"computed","precision":2},{"id":"annualEarnings","label":"Annual Earnings ($)","type":"computed","precision":2},{"id":"rpmVal","label":"RPM ($/1000 views)","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Traffic & Rates","fields":["dailyPageViews","ctr","cpc"]},{"id":"outputs","label":"Earnings","fields":["dailyClicks","dailyEarnings","monthlyEarnings","annualEarnings","rpmVal"]}],"formulas":{"dailyClicks":"dailyPageViews * ctr / 100","dailyEarnings":"dailyPageViews * ctr / 100 * cpc","monthlyEarnings":"dailyPageViews * ctr / 100 * cpc * 30","annualEarnings":"dailyPageViews * ctr / 100 * cpc * 365","rpmVal":"ctr / 100 * cpc * 1000"},"examples":[{"label":"10K views, 1.5% CTR, $0.35 CPC","inputs":{"dailyPageViews":10000,"ctr":1.5,"cpc":0.35}},{"label":"100K views, 2% CTR, $0.50 CPC","inputs":{"dailyPageViews":100000,"ctr":2,"cpc":0.50}}]}
