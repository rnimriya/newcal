{"id":"tithing","slug":"tithing-calculator","name":"Tithing Calculator","category":"finance","icon":"🙏","description":"Calculate your tithe (10%) and other giving amounts from your gross or net income.","tags":["tithing","tithe","giving","church","finance"],"fields":[{"id":"income","label":"Income ($)","type":"number","defaultValue":5000,"constraint":{"min":0,"step":0.01}},{"id":"tithePct","label":"Tithe Percentage (%)","type":"number","defaultValue":10,"constraint":{"min":0,"max":100,"step":0.1}},{"id":"titheAmount","label":"Tithe Amount ($)","type":"computed","precision":2},{"id":"offering5pct","label":"5% Offering ($)","type":"computed","precision":2},{"id":"offering15pct","label":"15% Offering ($)","type":"computed","precision":2},{"id":"remaining","label":"Remaining ($)","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"Income","fields":["income","tithePct"]},{"id":"outputs","label":"Giving","fields":["titheAmount","offering5pct","offering15pct","remaining"]}],"formulas":{"titheAmount":"income * tithePct / 100","offering5pct":"income * 0.05","offering15pct":"income * 0.15","remaining":"income - income * tithePct / 100"},"examples":[{"label":"$5,000 monthly income, 10%","inputs":{"income":5000,"tithePct":10}},{"label":"$3,000 at 10%","inputs":{"income":3000,"tithePct":10}}]}
