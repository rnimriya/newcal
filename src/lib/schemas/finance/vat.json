{"id":"vat","slug":"vat-calculator","name":"VAT Calculator","category":"finance","icon":"🧾","description":"Calculate VAT (Value Added Tax). Find tax amount, price before tax, and final price.","tags":["vat","tax","value added tax","finance"],"fields":[{"id":"priceBeforeVAT","label":"Price Before VAT ($)","type":"number","defaultValue":100,"constraint":{"min":0,"step":0.01}},{"id":"vatRate","label":"VAT Rate (%)","type":"number","defaultValue":20,"constraint":{"min":0,"max":100,"step":0.1}},{"id":"vatAmount","label":"VAT Amount ($)","type":"computed","precision":2},{"id":"priceAfterVAT","label":"Price After VAT ($)","type":"computed","precision":2},{"id":"vatFraction","label":"VAT as Fraction","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Price & Rate","fields":["priceBeforeVAT","vatRate"]},{"id":"outputs","label":"VAT Breakdown","fields":["vatAmount","priceAfterVAT","vatFraction"]}],"formulas":{"vatAmount":"priceBeforeVAT * vatRate / 100","priceAfterVAT":"priceBeforeVAT * (1 + vatRate/100)","vatFraction":"vatRate / (100 + vatRate)"},"examples":[{"label":"£100 at 20% UK VAT","inputs":{"priceBeforeVAT":100,"vatRate":20}},{"label":"€250 at 19% EU VAT","inputs":{"priceBeforeVAT":250,"vatRate":19}}]}
