{"id":"percent-to-ppm","slug":"percent-to-ppm","name":"Percent to PPM Converter","category":"converters","icon":"🔬","description":"Convert percentage concentration to parts per million (PPM). 1% = 10,000 PPM.","tags":["percent","ppm","parts per million","concentration","converter"],"fields":[{"id":"percent","label":"Percent (%)","type":"number","defaultValue":0.01,"constraint":{"min":0,"step":0.001}},{"id":"ppm","label":"PPM","type":"computed","precision":2},{"id":"ppb","label":"PPB (parts per billion)","type":"computed","precision":0},{"id":"ppt","label":"PPT (parts per trillion)","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Percent","fields":["percent"]},{"id":"outputs","label":"Converted","fields":["ppm","ppb","ppt"]}],"formulas":{"ppm":"percent * 10000","ppb":"percent * 10000000","ppt":"percent * 10000000000"},"examples":[{"label":"0.01% (drinking water limit)","inputs":{"percent":0.01}},{"label":"1%","inputs":{"percent":1}}]}
