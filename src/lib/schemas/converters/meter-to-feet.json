{"id":"meter-to-feet","slug":"meter-to-feet","name":"Meters to Feet Converter","category":"converters","icon":"📏","description":"Convert meters to feet and inches. 1 meter = 3.28084 feet.","tags":["meters","feet","length","converter"],"fields":[{"id":"meters","label":"Meters (m)","type":"number","defaultValue":1},{"id":"feet","label":"Feet (ft)","type":"computed","precision":6},{"id":"feetInt","label":"Feet (whole)","type":"computed","precision":0},{"id":"inchesRem","label":"Inches (remainder)","type":"computed","precision":2},{"id":"cm","label":"Centimeters (cm)","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"Meters","fields":["meters"]},{"id":"outputs","label":"Converted","fields":["feet","feetInt","inchesRem","cm"]}],"formulas":{"feet":"meters * 3.28084","feetInt":"floor(meters * 3.28084)","inchesRem":"(meters * 3.28084 - floor(meters * 3.28084)) * 12","cm":"meters * 100"},"examples":[{"label":"1 meter","inputs":{"meters":1}},{"label":"1.8 m (typical height)","inputs":{"meters":1.8}},{"label":"10 meters","inputs":{"meters":10}}]}
