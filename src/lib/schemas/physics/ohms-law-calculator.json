{
  "id": "ohms-law-calculator",
  "slug": "ohms-law-calculator",
  "name": "Ohm's Law Calculator",
  "category": "physics",
  "description": "Calculate voltage, current, or resistance based on Ohm's Law (V = I * R).",
  "icon": "⚡",
  "tags": ["ohms law", "voltage", "current", "resistance", "physics", "electricity"],
  "fields": [
    {
      "id": "mode",
      "label": "Calculate",
      "type": "select",
      "defaultValue": 1,
      "selectOptions": [
        { "label": "Voltage (V = I * R)",   "value": 1 },
        { "label": "Current (I = V / R)",   "value": 2 },
        { "label": "Resistance (R = V / I)", "value": 3 }
      ]
    },
    {
      "id": "v",
      "label": "Voltage (V)",
      "type": "number",
      "defaultValue": 12,
      "placeholder": "Enter voltage",
      "suffix": " V",
      "constraint": { "min": 0 }
    },
    {
      "id": "i",
      "label": "Current (I)",
      "type": "number",
      "defaultValue": 2,
      "placeholder": "Enter current",
      "suffix": " A",
      "constraint": { "min": 0 }
    },
    {
      "id": "r",
      "label": "Resistance (R)",
      "type": "number",
      "defaultValue": 6,
      "placeholder": "Enter resistance",
      "suffix": " Ω",
      "constraint": { "min": 0 }
    },
    {
      "id": "result",
      "label": "Computed Value",
      "type": "computed",
      "precision": 4,
      "helpText": "Calculated value based on selected mode"
    }
  ],
  "groups": [
    { "id": "config",  "label": "Mode Selection", "fields": ["mode"] },
    { "id": "inputs",  "label": "Inputs",         "fields": ["v", "i", "r"] },
    { "id": "outputs", "label": "Result",         "fields": ["result"] }
  ],
  "formulas": {
    "result": "mode == 1 ? i * r : (mode == 2 ? v / r : v / i)"
  },
  "examples": [
    { "label": "Calculate Voltage (I=2A, R=6Ω)", "inputs": { "mode": 1, "i": 2, "r": 6 } },
    { "label": "Calculate Current (V=12V, R=6Ω)", "inputs": { "mode": 2, "v": 12, "r": 6 } },
    { "label": "Calculate Resistance (V=12V, I=2A)", "inputs": { "mode": 3, "v": 12, "i": 2 } }
  ]
}
