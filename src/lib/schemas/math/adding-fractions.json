{"id":"adding-fractions","slug":"adding-fractions-calculator","name":"Adding Fractions Calculator","category":"math","icon":"½","description":"Add two fractions and get a simplified result. Shows LCM, common denominator, and simplified answer.","tags":["adding fractions","fractions","math"],"fields":[{"id":"n1","label":"Numerator 1","type":"number","defaultValue":1,"constraint":{"step":1}},{"id":"d1","label":"Denominator 1","type":"number","defaultValue":3,"constraint":{"min":1,"step":1}},{"id":"n2","label":"Numerator 2","type":"number","defaultValue":1,"constraint":{"step":1}},{"id":"d2","label":"Denominator 2","type":"number","defaultValue":4,"constraint":{"min":1,"step":1}},{"id":"lcd","label":"LCD (Least Common Denominator)","type":"computed","precision":0},{"id":"sumNum","label":"Sum Numerator","type":"computed","precision":0},{"id":"sumDen","label":"Sum Denominator","type":"computed","precision":0},{"id":"decimal","label":"Decimal Result","type":"computed","precision":8}],"groups":[{"id":"inputs","label":"Fractions","fields":["n1","d1","n2","d2"]},{"id":"outputs","label":"Sum","fields":["lcd","sumNum","sumDen","decimal"]}],"formulas":{"lcd":"(d1*d2)/gcd(d1,d2)","sumNum":"n1*(d1*d2/gcd(d1,d2))/d1 + n2*(d1*d2/gcd(d1,d2))/d2","sumDen":"(d1*d2)/gcd(d1,d2)","decimal":"n1/d1 + n2/d2"},"examples":[{"label":"1/3 + 1/4","inputs":{"n1":1,"d1":3,"n2":1,"d2":4}},{"label":"2/5 + 3/7","inputs":{"n1":2,"d1":5,"n2":3,"d2":7}}]}
