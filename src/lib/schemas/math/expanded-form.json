{"id":"expanded-form","slug":"expanded-form","name":"Expanded Form Calculator","category":"math","icon":"🔢","description":"Write any number in expanded form — breaking it into the sum of each digit's place value.","tags":["expanded form","place value","math"],"fields":[{"id":"number","label":"Number","type":"number","defaultValue":4527,"constraint":{"min":0,"max":999999,"step":1}},{"id":"thousands","label":"Thousands part","type":"computed","precision":0},{"id":"hundreds","label":"Hundreds part","type":"computed","precision":0},{"id":"tens","label":"Tens part","type":"computed","precision":0},{"id":"ones","label":"Ones part","type":"computed","precision":0},{"id":"check","label":"Sum (verification)","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Number","fields":["number"]},{"id":"outputs","label":"Expanded Form","fields":["thousands","hundreds","tens","ones","check"]}],"formulas":{"thousands":"floor(mod(floor(abs(number)),1000000)/1000)*1000","hundreds":"floor(mod(floor(abs(number)),1000)/100)*100","tens":"floor(mod(floor(abs(number)),100)/10)*10","ones":"mod(floor(abs(number)),10)","check":"floor(mod(floor(abs(number)),1000000)/1000)*1000+floor(mod(floor(abs(number)),1000)/100)*100+floor(mod(floor(abs(number)),100)/10)*10+mod(floor(abs(number)),10)"},"examples":[{"label":"4527","inputs":{"number":4527}},{"label":"10305","inputs":{"number":10305}}]}
