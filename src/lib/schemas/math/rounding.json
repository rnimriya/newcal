{"id":"rounding","slug":"rounding-calculator","name":"Rounding Calculator","category":"math","icon":"≈","description":"Round numbers to any decimal place, whole number, ten, hundred, or thousand.","tags":["round","decimal","significant figures","math"],"fields":[{"id":"number","label":"Number","type":"number","defaultValue":3.14159,"constraint":{"step":0.000001}},{"id":"places","label":"Decimal Places","type":"select","defaultValue":2,"selectOptions":[{"label":"0 (whole number)","value":0},{"label":"1 decimal","value":1},{"label":"2 decimals","value":2},{"label":"3 decimals","value":3},{"label":"4 decimals","value":4}]},{"id":"rounded","label":"Rounded Result","type":"computed","precision":4,"helpText":"Rounded to selected decimal places"},{"id":"roundedUp","label":"Rounded Up (Ceiling)","type":"computed","precision":4},{"id":"roundedDown","label":"Rounded Down (Floor)","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Input","fields":["number","places"]},{"id":"outputs","label":"Results","fields":["rounded","roundedUp","roundedDown"]}],"formulas":{"rounded":"round(number * 10^places) / 10^places","roundedUp":"ceil(number)","roundedDown":"floor(number)"},"examples":[{"label":"π to 2 places","inputs":{"number":3.14159,"places":2}},{"label":"√2 to 3 places","inputs":{"number":1.41421356,"places":3}}]}
