{"id":"exponential-notation","slug":"exponential-notation","name":"Exponential Notation Calculator","category":"math","icon":"10^","description":"Evaluate expressions in exponential notation a × bⁿ and convert to standard form.","tags":["exponential notation","scientific notation","math"],"fields":[{"id":"a","label":"Coefficient (a)","type":"number","defaultValue":3.5,"constraint":{"step":0.001}},{"id":"base","label":"Base (b)","type":"number","defaultValue":10,"constraint":{"step":1}},{"id":"exp","label":"Exponent (n)","type":"number","defaultValue":4,"constraint":{"step":1}},{"id":"result","label":"Result (a × bⁿ)","type":"computed","precision":6},{"id":"logResult","label":"log₁₀ of result","type":"computed","precision":6},{"id":"baseToExp","label":"bⁿ alone","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"a × bⁿ","fields":["a","base","exp"]},{"id":"outputs","label":"Result","fields":["result","baseToExp","logResult"]}],"formulas":{"result":"a * base^exp","baseToExp":"base^exp","logResult":"log10(abs(a * base^exp))"},"examples":[{"label":"3.5 × 10⁴","inputs":{"a":3.5,"base":10,"exp":4}},{"label":"2 × 2⁸","inputs":{"a":2,"base":2,"exp":8}}]}
