{"id":"volume-cylinder","slug":"volume-of-cylinder-calculator","name":"Volume of Cylinder Calculator","category":"math","icon":"🥫","description":"Calculate volume, surface area, and lateral area of a cylinder.","tags":["cylinder","volume","surface area","geometry"],"fields":[{"id":"radius","label":"Radius (r)","type":"number","defaultValue":3,"constraint":{"min":0,"step":0.1,"required":true}},{"id":"height","label":"Height (h)","type":"number","defaultValue":8,"constraint":{"min":0,"step":0.1,"required":true}},{"id":"volume","label":"Volume","type":"computed","precision":4,"suffix":" units³","helpText":"V = πr²h"},{"id":"surfaceArea","label":"Total Surface Area","type":"computed","precision":4,"suffix":" units²","helpText":"SA = 2πr(r + h)"},{"id":"lateralArea","label":"Lateral Surface Area","type":"computed","precision":4,"suffix":" units²","helpText":"LA = 2πrh"},{"id":"diameter","label":"Diameter","type":"computed","precision":4,"helpText":"d = 2r"}],"groups":[{"id":"inputs","label":"Dimensions","fields":["radius","height"]},{"id":"outputs","label":"Properties","fields":["volume","surfaceArea","lateralArea","diameter"]}],"formulas":{"volume":"pi*radius^2*height","surfaceArea":"2*pi*radius*(radius+height)","lateralArea":"2*pi*radius*height","diameter":"2*radius"},"examples":[{"label":"Soup can (r=3, h=8)","inputs":{"radius":3,"height":8}},{"label":"Water tank (r=5, h=10)","inputs":{"radius":5,"height":10}},{"label":"Unit cylinder","inputs":{"radius":1,"height":1}}],"chart":{"xAxisField":"height","yAxisField":"volume","xRange":[0.1,20],"points":40,"label":"Volume vs Height"}}
