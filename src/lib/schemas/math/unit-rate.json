{"id":"unit-rate","slug":"unit-rate","name":"Unit Rate Calculator","category":"math","icon":"÷","description":"Calculate the unit rate (per 1 unit) for any ratio of quantity to units.","tags":["unit rate","ratio","rate","math"],"fields":[{"id":"quantity","label":"Total Quantity","type":"number","defaultValue":150,"helpText":"e.g. 150 miles"},{"id":"units","label":"Number of Units","type":"number","defaultValue":3,"helpText":"e.g. 3 hours","constraint":{"min":0.001}},{"id":"unitRate","label":"Rate per Unit","type":"computed","precision":4,"helpText":"Quantity / Units"},{"id":"per10","label":"Rate per 10 Units","type":"computed","precision":4},{"id":"per100","label":"Rate per 100 Units","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Input","fields":["quantity","units"]},{"id":"outputs","label":"Unit Rates","fields":["unitRate","per10","per100"]}],"formulas":{"unitRate":"quantity/units","per10":"(quantity/units)*10","per100":"(quantity/units)*100"},"examples":[{"label":"150 miles in 3 hours","inputs":{"quantity":150,"units":3}},{"label":"$24 for 6 items","inputs":{"quantity":24,"units":6}}]}
