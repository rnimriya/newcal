{"id":"perimeter","slug":"perimeter-calculator","name":"Perimeter Calculator","category":"math","icon":"📏","description":"Calculate the perimeter of rectangles, squares, triangles, and circles.","tags":["perimeter","geometry","rectangle","square","triangle"],"fields":[{"id":"length","label":"Length (l)","type":"number","defaultValue":8,"constraint":{"min":0,"step":0.1,"required":true}},{"id":"width","label":"Width (w)","type":"number","defaultValue":5,"constraint":{"min":0,"step":0.1,"required":true}},{"id":"perimeterRect","label":"Rectangle Perimeter","type":"computed","precision":4,"helpText":"P = 2(l + w)"},{"id":"perimeterSquare","label":"Square Perimeter (using l)","type":"computed","precision":4,"helpText":"P = 4l"},{"id":"circleCircumference","label":"Circle Circumference (radius = l)","type":"computed","precision":4,"helpText":"C = 2πr"}],"groups":[{"id":"inputs","label":"Dimensions","fields":["length","width"]},{"id":"outputs","label":"Perimeters","fields":["perimeterRect","perimeterSquare","circleCircumference"]}],"formulas":{"perimeterRect":"2*(length+width)","perimeterSquare":"4*length","circleCircumference":"2*pi*length"},"examples":[{"label":"Room 8m × 5m","inputs":{"length":8,"width":5}},{"label":"A4 paper","inputs":{"length":29.7,"width":21}}]}
