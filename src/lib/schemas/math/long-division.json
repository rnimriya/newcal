{"id":"long-division","slug":"long-division","name":"Long Division Calculator","category":"math","icon":"÷","description":"Divide any two numbers and get the quotient, remainder, and decimal result.","tags":["long division","division","remainder","math"],"fields":[{"id":"dividend","label":"Dividend (a ÷ b)","type":"number","defaultValue":847,"constraint":{"step":1}},{"id":"divisor","label":"Divisor (b)","type":"number","defaultValue":13,"constraint":{"min":1,"step":1}},{"id":"quotient","label":"Quotient","type":"computed","precision":0},{"id":"remainder","label":"Remainder","type":"computed","precision":0},{"id":"decimal","label":"Decimal Result","type":"computed","precision":8}],"groups":[{"id":"inputs","label":"Division","fields":["dividend","divisor"]},{"id":"outputs","label":"Results","fields":["quotient","remainder","decimal"]}],"formulas":{"quotient":"floor(dividend/divisor)","remainder":"mod(dividend,divisor)","decimal":"dividend/divisor"},"examples":[{"label":"847 ÷ 13","inputs":{"dividend":847,"divisor":13}},{"label":"1000 ÷ 7","inputs":{"dividend":1000,"divisor":7}}]}
