{"id":"modulo","slug":"modulo-calculator","name":"Modulo Calculator","category":"math","icon":"%","description":"Find the remainder when dividing two integers (a mod b).","tags":["modulo","remainder","division","math"],"fields":[{"id":"dividend","label":"Dividend (a)","type":"number","defaultValue":17,"constraint":{"step":1}},{"id":"divisor","label":"Divisor (b)","type":"number","defaultValue":5,"constraint":{"step":1}},{"id":"quotient","label":"Quotient","type":"computed","precision":0,"helpText":"floor(a / b)"},{"id":"remainder","label":"Remainder (a mod b)","type":"computed","precision":0,"helpText":"a - b × floor(a/b)"}],"groups":[{"id":"inputs","label":"Input","fields":["dividend","divisor"]},{"id":"outputs","label":"Results","fields":["quotient","remainder"]}],"formulas":{"quotient":"floor(dividend/divisor)","remainder":"mod(dividend,divisor)"},"examples":[{"label":"17 mod 5 = 2","inputs":{"dividend":17,"divisor":5}},{"label":"100 mod 7","inputs":{"dividend":100,"divisor":7}},{"label":"Even/odd check: 8 mod 2","inputs":{"dividend":8,"divisor":2}}]}
