{
  "id": "arithmetic-sequence",
  "slug": "arithmetic-sequence",
  "name": "Arithmetic Sequence Calculator",
  "category": "math",
  "description": "Calculate the Nth term and the sum of the first N terms of an arithmetic progression.",
  "icon": "🔢",
  "tags": ["arithmetic sequence", "progression", "math", "series"],
  "fields": [
    {
      "id": "a1",
      "label": "First Term (a1)",
      "type": "number",
      "defaultValue": 1,
      "placeholder": "Enter a1",
      "constraint": { "required": true }
    },
    {
      "id": "d",
      "label": "Common Difference (d)",
      "type": "number",
      "defaultValue": 2,
      "placeholder": "Enter difference d",
      "constraint": { "required": true }
    },
    {
      "id": "n",
      "label": "Number of Terms (n)",
      "type": "number",
      "defaultValue": 10,
      "placeholder": "Enter term position n",
      "constraint": { "min": 1, "step": 1, "required": true }
    },
    {
      "id": "an",
      "label": "Nth Term (an)",
      "type": "computed",
      "precision": 4,
      "helpText": "a_n = a_1 + (n - 1) * d"
    },
    {
      "id": "sum",
      "label": "Sum of N Terms (Sn)",
      "type": "computed",
      "precision": 4,
      "helpText": "S_n = (n / 2) * (2*a_1 + (n - 1)*d)"
    }
  ],
  "groups": [
    { "id": "inputs",  "label": "Parameters", "fields": ["a1", "d", "n"] },
    { "id": "outputs", "label": "Results",    "fields": ["an", "sum"] }
  ],
  "formulas": {
    "an": "a1 + (n - 1) * d",
    "sum": "(n / 2) * (2 * a1 + (n - 1) * d)"
  },
  "examples": [
    { "label": "Odd numbers (1, 3, 5...) up to 10th term", "inputs": { "a1": 1, "d": 2, "n": 10 } },
    { "label": "Natural numbers (1, 2, 3...) up to 100th term", "inputs": { "a1": 1, "d": 1, "n": 100 } }
  ],
  "chart": {
    "xAxisField": "n",
    "yAxisField": "an",
    "xRange": [1, 25],
    "points": 25,
    "label": "Term Value vs Position n"
  }
}
