{"id":"fraction-to-percent","slug":"fraction-to-percent","name":"Fraction to Percent","category":"math","icon":"%","description":"Convert any fraction to a percentage quickly.","tags":["fraction","percent","convert","math"],"fields":[{"id":"numerator","label":"Numerator","type":"number","defaultValue":3,"constraint":{"step":1}},{"id":"denominator","label":"Denominator","type":"number","defaultValue":4,"constraint":{"min":1,"step":1}},{"id":"percent","label":"Percentage","type":"computed","precision":4,"suffix":"%"},{"id":"decimal","label":"Decimal","type":"computed","precision":8}],"groups":[{"id":"inputs","label":"Fraction","fields":["numerator","denominator"]},{"id":"outputs","label":"Results","fields":["percent","decimal"]}],"formulas":{"percent":"(numerator/denominator)*100","decimal":"numerator/denominator"},"examples":[{"label":"3/4 = 75%","inputs":{"numerator":3,"denominator":4}},{"label":"1/3 = 33.33%","inputs":{"numerator":1,"denominator":3}}]}
