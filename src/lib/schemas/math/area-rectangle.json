{
  "id": "area-rectangle",
  "slug": "area-of-rectangle-calculator",
  "name": "Area of Rectangle Calculator",
  "category": "math",
  "description": "Calculate area, perimeter, and diagonal of a rectangle.",
  "icon": "▭",
  "tags": ["rectangle", "area", "perimeter", "geometry"],
  "fields": [
    { "id": "length", "label": "Length (l)", "type": "number", "defaultValue": 8,  "constraint": { "min": 0, "step": 0.1 } },
    { "id": "width",  "label": "Width (w)",  "type": "number", "defaultValue": 5,  "constraint": { "min": 0, "step": 0.1 } },
    { "id": "area",      "label": "Area",      "type": "computed", "precision": 4, "helpText": "A = l × w" },
    { "id": "perimeter", "label": "Perimeter", "type": "computed", "precision": 4, "helpText": "P = 2(l + w)" },
    { "id": "diagonal",  "label": "Diagonal",  "type": "computed", "precision": 4, "helpText": "d = √(l² + w²)" }
  ],
  "groups": [
    { "id": "inputs",  "label": "Dimensions", "fields": ["length", "width"] },
    { "id": "outputs", "label": "Properties", "fields": ["area", "perimeter", "diagonal"] }
  ],
  "formulas": {
    "area":      "length * width",
    "perimeter": "2 * (length + width)",
    "diagonal":  "sqrt(length^2 + width^2)"
  },
  "examples": [
    { "label": "Standard room (4m × 5m)",  "inputs": { "length": 5, "width": 4 } },
    { "label": "A4 paper (21cm × 29.7cm)", "inputs": { "length": 29.7, "width": 21 } },
    { "label": "Football field",            "inputs": { "length": 100, "width": 68 } }
  ]
}
