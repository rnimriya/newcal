{"id":"place-value","slug":"place-value","name":"Place Value Calculator","category":"math","icon":"🔟","description":"Break any number into its place values: billions, millions, thousands, hundreds, tens, ones, and decimals.","tags":["place value","number sense","math"],"fields":[{"id":"number","label":"Number","type":"number","defaultValue":1234567.89,"constraint":{"step":0.01}},{"id":"millions","label":"Millions digit","type":"computed","precision":0},{"id":"thousands","label":"Thousands digit","type":"computed","precision":0},{"id":"hundreds","label":"Hundreds digit","type":"computed","precision":0},{"id":"tens","label":"Tens digit","type":"computed","precision":0},{"id":"ones","label":"Ones digit","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Number","fields":["number"]},{"id":"outputs","label":"Place Values","fields":["millions","thousands","hundreds","tens","ones"]}],"formulas":{"millions":"floor(mod(floor(abs(number)),1000000000)/1000000)","thousands":"floor(mod(floor(abs(number)),1000000)/1000)","hundreds":"floor(mod(floor(abs(number)),1000)/100)","tens":"floor(mod(floor(abs(number)),100)/10)","ones":"mod(floor(abs(number)),10)"},"examples":[{"label":"1,234,567.89","inputs":{"number":1234567.89}},{"label":"985","inputs":{"number":985}}]}
