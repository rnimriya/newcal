{"id":"factorial","slug":"factorial-calculator","name":"Factorial Calculator","category":"math","icon":"!","description":"Calculate n! for any non-negative integer up to 20.","tags":["factorial","combinatorics","math"],"fields":[{"id":"n","label":"n","type":"number","defaultValue":7,"placeholder":"e.g. 7","helpText":"Non-negative integer","constraint":{"min":0,"max":20,"step":1,"required":true}},{"id":"factorial","label":"n!","type":"computed","precision":0,"helpText":"n! = n × (n-1) × … × 1"},{"id":"permutations","label":"Permutations P(n,2)","type":"computed","precision":0,"helpText":"P(n,2) = n × (n-1)"},{"id":"combinations","label":"Combinations C(n,2)","type":"computed","precision":0,"helpText":"C(n,2) = n×(n-1)/2"}],"groups":[{"id":"inputs","label":"Input","fields":["n"]},{"id":"outputs","label":"Results","fields":["factorial","permutations","combinations"]}],"formulas":{"factorial":"factorial(n)","permutations":"n*(n-1)","combinations":"n*(n-1)/2"},"examples":[{"label":"5! (standard)","inputs":{"n":5}},{"label":"10!","inputs":{"n":10}},{"label":"0! = 1","inputs":{"n":0}}]}
