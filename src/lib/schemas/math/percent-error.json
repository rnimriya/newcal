{"id":"percent-error","slug":"percent-error-calculator","name":"Percent Error Calculator","category":"math","icon":"⚠️","description":"Calculate the percentage error between an observed (experimental) value and the theoretical (accepted) value.","tags":["percent error","accuracy","experimental","math"],"fields":[{"id":"observed","label":"Observed Value","type":"number","defaultValue":9.8,"helpText":"Your measured/experimental value"},{"id":"actual","label":"Actual (True) Value","type":"number","defaultValue":10,"helpText":"The accepted/theoretical value"},{"id":"error","label":"Absolute Error","type":"computed","precision":4,"helpText":"actual - observed"},{"id":"percentError","label":"Percent Error","type":"computed","precision":4,"suffix":"%","helpText":"(|observed-actual|/actual) × 100"}],"groups":[{"id":"inputs","label":"Values","fields":["observed","actual"]},{"id":"outputs","label":"Error","fields":["error","percentError"]}],"formulas":{"error":"abs(observed-actual)","percentError":"(abs(observed-actual)/abs(actual))*100"},"examples":[{"label":"Physics experiment","inputs":{"observed":9.8,"actual":10}},{"label":"Chemistry lab","inputs":{"observed":4.85,"actual":5}},{"label":"Measurement error","inputs":{"observed":102,"actual":100}}]}
