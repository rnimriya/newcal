{"id":"cube-root","slug":"cube-root-calculator","name":"Cube Root Calculator","category":"math","icon":"∛","description":"Calculate the cube root of any number, including negative numbers.","tags":["cube root","radical","math"],"fields":[{"id":"x","label":"Number (x)","type":"number","defaultValue":27,"helpText":"Can be negative"},{"id":"cubeRoot","label":"Cube Root (∛x)","type":"computed","precision":10,"helpText":"∛x = x^(1/3)"},{"id":"cube","label":"x³ (verification)","type":"computed","precision":4,"helpText":"Cubing the root confirms the answer"}],"groups":[{"id":"inputs","label":"Input","fields":["x"]},{"id":"outputs","label":"Results","fields":["cubeRoot","cube"]}],"formulas":{"cubeRoot":"x >= 0 ? x^(1/3) : -(abs(x)^(1/3))","cube":"(x >= 0 ? x^(1/3) : -(abs(x)^(1/3)))^3"},"examples":[{"label":"∛27 = 3","inputs":{"x":27}},{"label":"∛8 = 2","inputs":{"x":8}},{"label":"∛125 = 5","inputs":{"x":125}},{"label":"Negative: ∛-8","inputs":{"x":-8}}]}
