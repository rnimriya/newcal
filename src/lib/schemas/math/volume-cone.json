{
  "id": "volume-cone",
  "slug": "volume-cone",
  "name": "Volume of Cone Calculator",
  "category": "math",
  "description": "Calculate the volume, lateral surface area, and total surface area of a circular cone.",
  "icon": "📐",
  "tags": ["cone", "volume", "surface area", "geometry"],
  "fields": [
    {
      "id": "radius",
      "label": "Radius (r)",
      "type": "number",
      "defaultValue": 3,
      "placeholder": "Enter radius",
      "units": [
        { "label": "Meters (m)",       "value": "m",  "toBase": "x",         "fromBase": "x" },
        { "label": "Centimeters (cm)", "value": "cm", "toBase": "x / 100",   "fromBase": "x * 100" },
        { "label": "Feet (ft)",        "value": "ft", "toBase": "x * 0.3048","fromBase": "x / 0.3048" }
      ],
      "defaultUnit": "m",
      "constraint": { "min": 0, "required": true }
    },
    {
      "id": "height",
      "label": "Height (h)",
      "type": "number",
      "defaultValue": 5,
      "placeholder": "Enter height",
      "units": [
        { "label": "Meters (m)",       "value": "m",  "toBase": "x",         "fromBase": "x" },
        { "label": "Centimeters (cm)", "value": "cm", "toBase": "x / 100",   "fromBase": "x * 100" },
        { "label": "Feet (ft)",        "value": "ft", "toBase": "x * 0.3048","fromBase": "x / 0.3048" }
      ],
      "defaultUnit": "m",
      "constraint": { "min": 0, "required": true }
    },
    {
      "id": "volume",
      "label": "Volume",
      "type": "computed",
      "precision": 4,
      "suffix": " m³",
      "helpText": "V = (1/3) * π * r² * h"
    },
    {
      "id": "slantHeight",
      "label": "Slant Height (s)",
      "type": "computed",
      "precision": 4,
      "suffix": " m",
      "helpText": "s = √(r² + h²)"
    },
    {
      "id": "surfaceArea",
      "label": "Total Surface Area",
      "type": "computed",
      "precision": 4,
      "suffix": " m²",
      "helpText": "A = π * r * (r + s)"
    }
  ],
  "groups": [
    { "id": "inputs",  "label": "Dimensions",   "fields": ["radius", "height"] },
    { "id": "outputs", "label": "Calculated Properties", "fields": ["volume", "slantHeight", "surfaceArea"] }
  ],
  "formulas": {
    "volume": "(1/3) * PI * radius^2 * height",
    "slantHeight": "sqrt(radius^2 + height^2)",
    "surfaceArea": "PI * radius * (radius + sqrt(radius^2 + height^2))"
  },
  "examples": [
    { "label": "r = 3, h = 5", "inputs": { "radius": 3, "height": 5 } },
    { "label": "r = 5, h = 12", "inputs": { "radius": 5, "height": 12 } }
  ],
  "chart": {
    "xAxisField": "radius",
    "yAxisField": "volume",
    "xRange": [0.1, 10],
    "points": 40,
    "label": "Volume vs Radius (at fixed Height)"
  }
}
