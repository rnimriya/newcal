{
  "id": "foil-method-calculator",
  "slug": "foil-method-calculator",
  "name": "FOIL Method Calculator",
  "category": "algebra",
  "icon": "🧮",
  "description": "Expand binomials using FOIL: (ax + b)(cx + d) step by step.",
  "tags": [
    "FOIL",
