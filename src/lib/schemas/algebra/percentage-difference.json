{"id":"percentage-difference","slug":"percentage-difference","name":"Percentage Difference Calculator","category":"algebra","icon":"↔️","description":"Calculate the percentage difference between two values (non-directional).","tags":["percentage difference","comparison","algebra"],"fields":[{"id":"v1","label":"Value 1","type":"number","defaultValue":60,"constraint":{"step":0.01}},{"id":"v2","label":"Value 2","type":"number","defaultValue":80},{"id":"absDiff","label":"Absolute Difference","type":"computed","precision":4},{"id":"avgVal","label":"Average of Values","type":"computed","precision":4},{"id":"pctDiff","label":"Percentage Difference (%)","type":"computed","precision":4,"helpText":"|v1 - v2| / ((v1 + v2)/2) × 100"}],"groups":[{"id":"inputs","label":"Values","fields":["v1","v2"]},{"id":"outputs","label":"Difference","fields":["absDiff","avgVal","pctDiff"]}],"formulas":{"absDiff":"abs(v1 - v2)","avgVal":"(v1 + v2) / 2","pctDiff":"(abs(v1 - v2) / ((v1 + v2) / 2)) * 100"},"examples":[{"label":"60 vs 80","inputs":{"v1":60,"v2":80}},{"label":"Compare 150 and 200","inputs":{"v1":150,"v2":200}}]}
