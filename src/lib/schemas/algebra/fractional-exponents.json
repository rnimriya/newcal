{"id":"fractional-exponents","slug":"fractional-exponents","name":"Fractional Exponents Calculator","category":"algebra","icon":"xⁿ","description":"Calculate values with fractional exponents: x^(m/n) = ⁿ√(xᵐ). Handles negative bases for odd roots.","tags":["fractional exponents","radicals","algebra","math"],"fields":[{"id":"base","label":"Base (x)","type":"number","defaultValue":8,"constraint":{"step":0.01}},{"id":"m","label":"Numerator of exponent (m)","type":"number","defaultValue":2,"constraint":{"step":1}},{"id":"n","label":"Denominator of exponent (n)","type":"number","defaultValue":3,"constraint":{"min":1,"step":1}},{"id":"result","label":"x^(m/n)","type":"computed","precision":8,"helpText":"= ⁿ√(xᵐ)"},{"id":"xToM","label":"xᵐ","type":"computed","precision":6},{"id":"exponent","label":"Exponent fraction (m/n)","type":"computed","precision":6}],"groups":[{"id":"inputs","label":"x^(m/n)","fields":["base","m","n"]},{"id":"outputs","label":"Result","fields":["result","xToM","exponent"]}],"formulas":{"result":"base >= 0 ? base^(m/n) : -(abs(base)^(m/n))","xToM":"base^m","exponent":"m/n"},"examples":[{"label":"8^(2/3) = 4","inputs":{"base":8,"m":2,"n":3}},{"label":"16^(3/4) = 8","inputs":{"base":16,"m":3,"n":4}},{"label":"27^(1/3) = 3","inputs":{"base":27,"m":1,"n":3}}]}
