{"id":"percentage-increase","slug":"percentage-increase","name":"Percentage Increase Calculator","category":"algebra","icon":"📈","description":"Calculate the percentage increase between two values.","tags":["percentage increase","percent change","algebra"],"fields":[{"id":"original","label":"Original Value","type":"number","defaultValue":80,"constraint":{"step":0.01}},{"id":"newValue","label":"New Value","type":"number","defaultValue":100},{"id":"increase","label":"Absolute Increase","type":"computed","precision":4},{"id":"percentIncrease","label":"Percentage Increase (%)","type":"computed","precision":4,"helpText":"((new - original) / original) × 100"},{"id":"multiplier","label":"Multiplier","type":"computed","precision":6,"helpText":"new / original"}],"groups":[{"id":"inputs","label":"Values","fields":["original","newValue"]},{"id":"outputs","label":"Increase","fields":["increase","percentIncrease","multiplier"]}],"formulas":{"increase":"newValue - original","percentIncrease":"((newValue - original) / abs(original)) * 100","multiplier":"newValue / original"},"examples":[{"label":"80 to 100","inputs":{"original":80,"newValue":100}},{"label":"Price rise: 250 to 310","inputs":{"original":250,"newValue":310}}]}
