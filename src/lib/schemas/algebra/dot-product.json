{
  "id": "dot-product-calculator",
  "slug": "dot-product-calculator",
  "name": "Dot Product Calculator",
  "category": "algebra",
  "icon": "·",
  "description": "Calculate the dot product of two 3D vectors and find the angle between them.",
  "tags": [
    "dot product",
    "vector",
    "angle",
    "algebra",
    "linear algebra"
  ],
  "fields": [
    {
      "id": "a1",
      "label": "Vector A — x",
      "type": "number",
      "defaultValue": 1
    },
    {
      "id": "a2",
      "label": "Vector A — y",
      "type": "number",
      "defaultValue": 2
    },
    {
      "id": "a3",
      "label": "Vector A — z",
      "type": "number",
      "defaultValue": 3
    },
    {
      "id": "b1",
      "label": "Vector B — x",
      "type": "number",
      "defaultValue": 4
    },
    {
      "id": "b2",
      "label": "Vector B — y",
      "type": "number",
      "defaultValue": 5
    },
    {
      "id": "b3",
      "label": "Vector B — z",
      "type": "number",
      "defaultValue": 6
    },
    {
      "id": "dotProduct",
      "label": "Dot Product (A·B)",
      "type": "computed",
      "precision": 4
    },
    {
      "id": "magA",
      "label": "|A| (magnitude of A)",
      "type": "computed",
      "precision": 4
    },
    {
      "id": "magB",
      "label": "|B| (magnitude of B)",
      "type": "computed",
      "precision": 4
    },
    {
      "id": "angleRad",
      "label": "Angle (radians)",
      "type": "computed",
      "precision": 6
    },
    {
      "id": "angleDeg",
      "label": "Angle (degrees)",
      "type": "computed",
      "precision": 4
    }
  ],
  "groups": [
    {
      "id": "inputs",
      "label": "Vectors",
      "fields": [
        "a1",
        "a2",
        "a3",
        "b1",
        "b2",
        "b3"
      ]
    },
    {
      "id": "outputs",
      "label": "Results",
      "fields": [
        "dotProduct",
        "magA",
        "magB",
        "angleRad",
        "angleDeg"
      ]
    }
  ],
  "formulas": {
    "dotProduct": "a1*b1 + a2*b2 + a3*b3",
    "magA": "sqrt(a1^2 + a2^2 + a3^2)",
    "magB": "sqrt(b1^2 + b2^2 + b3^2)",
    "angleRad": "acos((a1*b1 + a2*b2 + a3*b3) / (sqrt(a1^2 + a2^2 + a3^2) * sqrt(b1^2 + b2^2 + b3^2)))",
    "angleDeg": "acos((a1*b1 + a2*b2 + a3*b3) / (sqrt(a1^2 + a2^2 + a3^2) * sqrt(b1^2 + b2^2 + b3^2))) * 180 / pi"
  },
  "examples": [
    {
      "label": "[1,2,3] · [4,5,6]",
      "inputs": {
        "a1": 1,
        "a2": 2,
        "a3": 3,
        "b1": 4,
        "b2": 5,
        "b3": 6
      }
    },
    {
      "label": "Perpendicular vectors",
      "inputs": {
        "a1": 1,
        "a2": 0,
        "a3": 0,
        "b1": 0,
        "b2": 1,
        "b3": 0
      }
    }
  ]
}