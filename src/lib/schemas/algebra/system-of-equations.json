{"id":"system-of-equations","slug":"system-of-equations","name":"System of Equations Calculator","category":"algebra","icon":"⟨⟩","description":"Solve a 2×2 system of linear equations: a₁x + b₁y = c₁ and a₂x + b₂y = c₂ using Cramer's rule.","tags":["system of equations","algebra","linear equations","solve"],"fields":[{"id":"a1","label":"a₁ (coeff of x, eq 1)","type":"number","defaultValue":2},{"id":"b1","label":"b₁ (coeff of y, eq 1)","type":"number","defaultValue":3},{"id":"c1","label":"c₁ (constant, eq 1)","type":"number","defaultValue":8},{"id":"a2","label":"a₂ (coeff of x, eq 2)","type":"number","defaultValue":1},{"id":"b2","label":"b₂ (coeff of y, eq 2)","type":"number","defaultValue":-1},{"id":"c2","label":"c₂ (constant, eq 2)","type":"number","defaultValue":1},{"id":"det","label":"Determinant (D)","type":"computed","precision":4,"helpText":"a₁b₂ - a₂b₁"},{"id":"x","label":"x","type":"computed","precision":6,"helpText":"Dx / D"},{"id":"y","label":"y","type":"computed","precision":6,"helpText":"Dy / D"}],"groups":[{"id":"inputs","label":"Equation 1: a₁x + b₁y = c₁","fields":["a1","b1","c1"]},{"id":"eq2","label":"Equation 2: a₂x + b₂y = c₂","fields":["a2","b2","c2"]},{"id":"outputs","label":"Solution","fields":["det","x","y"]}],"formulas":{"det":"a1*b2 - a2*b1","x":"(c1*b2 - c2*b1) / (a1*b2 - a2*b1)","y":"(a1*c2 - a2*c1) / (a1*b2 - a2*b1)"},"examples":[{"label":"2x + 3y = 8, x - y = 1","inputs":{"a1":2,"b1":3,"c1":8,"a2":1,"b2":-1,"c2":1}},{"label":"3x + 2y = 12, x + 4y = 8","inputs":{"a1":3,"b1":2,"c1":12,"a2":1,"b2":4,"c2":8}}]}
