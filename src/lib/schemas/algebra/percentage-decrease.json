{"id":"percentage-decrease","slug":"percentage-decrease","name":"Percentage Decrease Calculator","category":"algebra","icon":"📉","description":"Calculate the percentage decrease between two values.","tags":["percentage decrease","percent change","algebra"],"fields":[{"id":"original","label":"Original Value","type":"number","defaultValue":100,"constraint":{"step":0.01}},{"id":"newValue","label":"New Value","type":"number","defaultValue":80},{"id":"decrease","label":"Absolute Decrease","type":"computed","precision":4},{"id":"percentDecrease","label":"Percentage Decrease (%)","type":"computed","precision":4,"helpText":"((original - new) / original) × 100"},{"id":"retainedPct","label":"Value Retained (%)","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Values","fields":["original","newValue"]},{"id":"outputs","label":"Decrease","fields":["decrease","percentDecrease","retainedPct"]}],"formulas":{"decrease":"original - newValue","percentDecrease":"((original - newValue) / abs(original)) * 100","retainedPct":"(newValue / original) * 100"},"examples":[{"label":"100 to 80","inputs":{"original":100,"newValue":80}},{"label":"Sale: 200 to 150","inputs":{"original":200,"newValue":150}}]}
