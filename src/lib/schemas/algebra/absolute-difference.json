{"id":"absolute-difference","slug":"absolute-difference","name":"Absolute Difference Calculator","category":"algebra","icon":"||","description":"Find the absolute difference |a - b| between two numbers, along with relative difference and ratio.","tags":["absolute difference","algebra","math"],"fields":[{"id":"a","label":"Value A","type":"number","defaultValue":15},{"id":"b","label":"Value B","type":"number","defaultValue":9},{"id":"absDiff","label":"|A - B|","type":"computed","precision":4},{"id":"relDiff","label":"Relative Difference (%)","type":"computed","precision":4,"helpText":"|A-B| / ((A+B)/2) × 100"},{"id":"ratio","label":"A : B ratio (simplified)","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Values","fields":["a","b"]},{"id":"outputs","label":"Results","fields":["absDiff","relDiff","ratio"]}],"formulas":{"absDiff":"abs(a - b)","relDiff":"abs(a-b)/((abs(a)+abs(b))/2)*100","ratio":"a/gcd(round(abs(a)),round(abs(b)))"},"examples":[{"label":"15 and 9","inputs":{"a":15,"b":9}},{"label":"100 and 75","inputs":{"a":100,"b":75}}]}
