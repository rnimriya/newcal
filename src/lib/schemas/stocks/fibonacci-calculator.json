{
  "id": "fibonacci-retracement",
  "slug": "fibonacci-calculator",
  "name": "Fibonacci Retracement Calculator",
  "category": "stocks",
  "description": "Calculate Fibonacci retracement levels for technical analysis based on a price swing high and low.",
  "icon": "🐚",
  "tags": ["Fibonacci", "retracement", "technical analysis", "support resistance", "trading levels"],
  "fields": [
    { "id": "high", "label": "Swing High", "type": "number", "defaultValue": 200, "prefix": "$", "constraint": { "min": 0.01, "step": 0.01, "required": true } },
    { "id": "low", "label": "Swing Low", "type": "number", "defaultValue": 100, "prefix": "$", "constraint": { "min": 0.01, "step": 0.01, "required": true } },
    { "id": "level0", "label": "0% Level", "type": "computed", "precision": 2, "prefix": "$" },
    { "id": "level236", "label": "23.6% Level", "type": "computed", "precision": 2, "prefix": "$" },
    { "id": "level382", "label": "38.2% Level", "type": "computed", "precision": 2, "prefix": "$" },
    { "id": "level500", "label": "50.0% Level", "type": "computed", "precision": 2, "prefix": "$" },
    { "id": "level618", "label": "61.8% Level", "type": "computed", "precision": 2, "prefix": "$" },
    { "id": "level786", "label": "78.6% Level", "type": "computed", "precision": 2, "prefix": "$" },
    { "id": "level100", "label": "100% Level", "type": "computed", "precision": 2, "prefix": "$" }
  ],
  "groups": [
    { "id": "inputs", "label": "Price Swing", "fields": ["high", "low"] },
    { "id": "outputs", "label": "Fibonacci Levels", "fields": ["level0", "level236", "level382", "level500", "level618", "level786", "level100"] }
  ],
  "formulas": {
    "level0": "low",
    "level236": "low + (high - low) * 0.236",
    "level382": "low + (high - low) * 0.382",
    "level500": "low + (high - low) * 0.5",
    "level618": "low + (high - low) * 0.618",
    "level786": "low + (high - low) * 0.786",
    "level100": "high"
  },
  "examples": [
    { "label": "Bull run retracement", "inputs": { "high": 200, "low": 100 } },
    { "label": "Tech stock swing", "inputs": { "high": 350, "low": 250 } },
    { "label": "S&P 500 swing", "inputs": { "high": 5000, "low": 4500 } }
  ],
  "explanation": "Fibonacci retracement levels (23.6%, 38.2%, 50%, 61.8%, 78.6%) are based on the Fibonacci sequence's golden ratio. Traders use these levels to identify potential areas where price may pause or reverse during a correction. The 61.8% level (golden ratio) is considered particularly significant."
}
