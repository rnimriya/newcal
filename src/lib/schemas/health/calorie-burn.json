{"id":"calorie-burn","slug":"calorie-burn-calculator","name":"Calorie Burn Calculator","category":"health","icon":"🔥","description":"Estimate calories burned during exercise based on activity, weight, and duration.","tags":["calories burned","exercise","fitness","health"],"fields":[{"id":"weight","label":"Body Weight (kg)","type":"number","defaultValue":70,"constraint":{"min":20,"max":300,"step":0.5}},{"id":"met","label":"MET Value","type":"number","defaultValue":7,"constraint":{"min":0.5,"max":20,"step":0.5},"helpText":"Running=7-12, Walking=3.5, Cycling=6-10"},{"id":"duration","label":"Duration (minutes)","type":"number","defaultValue":30,"constraint":{"min":1,"step":1}},{"id":"caloriesBurned","label":"Calories Burned (kcal)","type":"computed","precision":0},{"id":"perMinute","label":"Calories per Minute","type":"computed","precision":2},{"id":"perHour","label":"Calories per Hour","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Activity","fields":["weight","met","duration"]},{"id":"outputs","label":"Calories","fields":["caloriesBurned","perMinute","perHour"]}],"formulas":{"caloriesBurned":"met * weight * duration / 60","perMinute":"met * weight / 60","perHour":"met * weight"},"explanation":"## MET Values\n\n| Activity | MET |\n|----------|-----|\n| Walking (3.5 mph) | 4.3 |\n| Running (6 mph) | 9.8 |\n| Cycling (moderate) | 8 |\n| Swimming | 6 |\n| Strength training | 5 |\n| Yoga | 2.5 |","examples":[{"label":"70kg jogging 30 min","inputs":{"weight":70,"met":7,"duration":30}},{"label":"80kg cycling 45 min","inputs":{"weight":80,"met":8,"duration":45}}]}
