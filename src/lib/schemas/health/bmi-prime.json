{"id":"bmi-prime","slug":"bmi-prime","name":"BMI Prime Calculator","category":"health","icon":"📊","description":"Calculate BMI Prime — ratio of your BMI to the upper limit of normal weight (25).","tags":["bmi prime","bmi","health"],"fields":[{"id":"weight","label":"Weight (kg)","type":"number","defaultValue":70},{"id":"height","label":"Height (cm)","type":"number","defaultValue":175},{"id":"bmi","label":"BMI","type":"computed","precision":2},{"id":"bmiPrime","label":"BMI Prime","type":"computed","precision":4},{"id":"healthyWeightMin","label":"Healthy Weight Min (kg)","type":"computed","precision":1},{"id":"healthyWeightMax","label":"Healthy Weight Max (kg)","type":"computed","precision":1},{"id":"weightToLose","label":"Weight to Lose for Healthy BMI (kg)","type":"computed","precision":1}],"groups":[{"id":"inputs","label":"Measurements","fields":["weight","height"]},{"id":"outputs","label":"Results","fields":["bmi","bmiPrime","healthyWeightMin","healthyWeightMax","weightToLose"]}],"formulas":{"bmi":"weight / (height/100)^2","bmiPrime":"weight / (height/100)^2 / 25","healthyWeightMin":"18.5 * (height/100)^2","healthyWeightMax":"25 * (height/100)^2","weightToLose":"max(0, weight - 25 * (height/100)^2)"},"examples":[{"label":"70kg, 175cm","inputs":{"weight":70,"height":175}},{"label":"90kg, 170cm","inputs":{"weight":90,"height":170}}]}
