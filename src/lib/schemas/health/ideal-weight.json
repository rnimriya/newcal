{"id":"ideal-weight","slug":"ideal-weight-calculator","name":"Ideal Weight Calculator","category":"health","icon":"⚖️","description":"Calculate ideal body weight using multiple formulas: Devine, Robinson, Miller, and Hamwi.","tags":["ideal weight","healthy weight","BMI","health"],"fields":[{"id":"height","label":"Height (cm)","type":"number","defaultValue":170,"constraint":{"min":100,"max":250,"step":1}},{"id":"heightInches","label":"Height above 5ft (inches)","type":"computed","precision":1,"helpText":"Used in formulas — height in inches minus 60"},{"id":"devineM","label":"Devine (male) kg","type":"computed","precision":1,"helpText":"50 + 2.3 × (inches above 5ft)"},{"id":"devineF","label":"Devine (female) kg","type":"computed","precision":1,"helpText":"45.5 + 2.3 × (inches above 5ft)"},{"id":"millerM","label":"Miller (male) kg","type":"computed","precision":1},{"id":"millerF","label":"Miller (female) kg","type":"computed","precision":1}],"groups":[{"id":"inputs","label":"Height","fields":["height"]},{"id":"outputs","label":"Ideal Weight","fields":["heightInches","devineM","devineF","millerM","millerF"]}],"formulas":{"heightInches":"height / 2.54 - 60","devineM":"50 + 2.3 * (height / 2.54 - 60)","devineF":"45.5 + 2.3 * (height / 2.54 - 60)","millerM":"56.2 + 1.41 * (height / 2.54 - 60)","millerF":"53.1 + 1.36 * (height / 2.54 - 60)"},"examples":[{"label":"170 cm","inputs":{"height":170}},{"label":"180 cm","inputs":{"height":180}}]}
