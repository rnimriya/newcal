{"id":"lean-body-mass","slug":"lean-body-mass","name":"Lean Body Mass Calculator","category":"health","icon":"💪","description":"Calculate lean body mass from total weight and body fat percentage.","tags":["lean body mass","lbm","body composition","health"],"fields":[{"id":"weight","label":"Body Weight (kg)","type":"number","defaultValue":75},{"id":"bodyFatPct","label":"Body Fat %","type":"number","defaultValue":18},{"id":"lbm","label":"Lean Body Mass (kg)","type":"computed","precision":2},{"id":"fatMass","label":"Fat Mass (kg)","type":"computed","precision":2},{"id":"lbmLbs","label":"Lean Body Mass (lbs)","type":"computed","precision":2},{"id":"fatPctNeeded","label":"Fat Mass (%)","type":"computed","precision":2,"suffix":"%"}],"groups":[{"id":"inputs","label":"Body Composition","fields":["weight","bodyFatPct"]},{"id":"outputs","label":"Results","fields":["lbm","fatMass","lbmLbs","fatPctNeeded"]}],"formulas":{"lbm":"weight * (1 - bodyFatPct/100)","fatMass":"weight * bodyFatPct/100","lbmLbs":"weight * (1 - bodyFatPct/100) * 2.20462","fatPctNeeded":"bodyFatPct"},"examples":[{"label":"75kg, 18% BF","inputs":{"weight":75,"bodyFatPct":18}},{"label":"60kg, 25% BF","inputs":{"weight":60,"bodyFatPct":25}}]}
