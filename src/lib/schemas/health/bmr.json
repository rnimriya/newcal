{"id":"bmr","slug":"bmr-calculator","name":"BMR Calculator","category":"health","icon":"💪","description":"Calculate your Basal Metabolic Rate (BMR) — the calories your body burns at rest using the Mifflin-St Jeor equation.","tags":["BMR","basal metabolic rate","calories","health","weight loss"],"fields":[{"id":"weight","label":"Weight (kg)","type":"number","defaultValue":70,"constraint":{"min":20,"max":300,"step":0.5}},{"id":"height","label":"Height (cm)","type":"number","defaultValue":170,"constraint":{"min":100,"max":250,"step":1}},{"id":"age","label":"Age (years)","type":"number","defaultValue":30,"constraint":{"min":15,"max":100,"step":1}},{"id":"sexFactor","label":"Sex Factor (male=5, female=-161)","type":"number","defaultValue":5,"constraint":{"min":-161,"max":5,"step":166}},{"id":"bmr","label":"BMR (kcal/day)","type":"computed","precision":0,"helpText":"Mifflin-St Jeor equation"},{"id":"tdeeModerate","label":"TDEE Moderate Active (kcal)","type":"computed","precision":0},{"id":"tdeeActive","label":"TDEE Active (kcal)","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Body Details","fields":["weight","height","age","sexFactor"]},{"id":"outputs","label":"Calories","fields":["bmr","tdeeModerate","tdeeActive"]}],"formulas":{"bmr":"10 * weight + 6.25 * height - 5 * age + sexFactor","tdeeModerate":"(10 * weight + 6.25 * height - 5 * age + sexFactor) * 1.55","tdeeActive":"(10 * weight + 6.25 * height - 5 * age + sexFactor) * 1.725"},"examples":[{"label":"Male, 70kg, 170cm, 30 years","inputs":{"weight":70,"height":170,"age":30,"sexFactor":5}},{"label":"Female, 60kg, 160cm, 25 years","inputs":{"weight":60,"height":160,"age":25,"sexFactor":-161}}]}
