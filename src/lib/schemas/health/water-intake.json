{"id":"water-intake","slug":"water-intake-calculator","name":"Water Intake Calculator","category":"health","icon":"💧","description":"Calculate your daily recommended water intake based on body weight and activity level.","tags":["water intake","hydration","health","fitness"],"fields":[{"id":"weight","label":"Body Weight (kg)","type":"number","defaultValue":70,"constraint":{"min":20,"max":300,"step":0.5}},{"id":"activityMultiplier","label":"Activity Level (1=sedentary, 1.5=active)","type":"number","defaultValue":1.2,"constraint":{"min":1,"max":2,"step":0.1}},{"id":"litersPerDay","label":"Water per Day (liters)","type":"computed","precision":2},{"id":"cupsPerDay","label":"Cups per Day (240mL)","type":"computed","precision":0},{"id":"ozPerDay","label":"Fluid Ounces per Day","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Your Info","fields":["weight","activityMultiplier"]},{"id":"outputs","label":"Daily Intake","fields":["litersPerDay","cupsPerDay","ozPerDay"]}],"formulas":{"litersPerDay":"weight * 0.033 * activityMultiplier","cupsPerDay":"weight * 0.033 * activityMultiplier * 1000 / 240","ozPerDay":"weight * 0.033 * activityMultiplier * 33.814"},"examples":[{"label":"70kg sedentary","inputs":{"weight":70,"activityMultiplier":1}},{"label":"80kg active","inputs":{"weight":80,"activityMultiplier":1.5}}]}
