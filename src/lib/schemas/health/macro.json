{"id":"macro-calculator","slug":"macro-calculator","name":"Macro Calculator","category":"health","icon":"🥗","description":"Calculate daily protein, carbohydrate, and fat targets from your TDEE and goal.","tags":["macros","protein","carbs","fat","nutrition"],"fields":[{"id":"tdee","label":"TDEE (calories/day)","type":"number","defaultValue":2200},{"id":"proteinPct","label":"Protein % of calories","type":"number","defaultValue":30},{"id":"fatPct","label":"Fat % of calories","type":"number","defaultValue":30},{"id":"carbPct","label":"Carb % of calories","type":"computed","precision":1,"suffix":"%"},{"id":"proteinG","label":"Protein (g/day)","type":"computed","precision":1},{"id":"fatG","label":"Fat (g/day)","type":"computed","precision":1},{"id":"carbG","label":"Carbs (g/day)","type":"computed","precision":1},{"id":"proteinCal","label":"Protein calories","type":"computed","precision":1},{"id":"fatCal","label":"Fat calories","type":"computed","precision":1}],"groups":[{"id":"inputs","label":"Calorie & Macro Split","fields":["tdee","proteinPct","fatPct"]},{"id":"outputs","label":"Daily Targets","fields":["carbPct","proteinG","fatG","carbG","proteinCal","fatCal"]}],"formulas":{"carbPct":"100 - proteinPct - fatPct","proteinG":"tdee * proteinPct / 100 / 4","fatG":"tdee * fatPct / 100 / 9","carbG":"tdee * (100 - proteinPct - fatPct) / 100 / 4","proteinCal":"tdee * proteinPct / 100","fatCal":"tdee * fatPct / 100"},"examples":[{"label":"Balanced 2200 cal","inputs":{"tdee":2200,"proteinPct":30,"fatPct":30}},{"label":"High protein 2500 cal","inputs":{"tdee":2500,"proteinPct":40,"fatPct":25}}]}
