{"id":"blood-pressure-categories","slug":"blood-pressure-categories","name":"Blood Pressure Categories","category":"health","icon":"🩺","description":"Classify systolic and diastolic blood pressure by AHA guidelines and calculate mean arterial pressure.","tags":["blood pressure","hypertension","health"],"fields":[{"id":"systolic","label":"Systolic (mmHg)","type":"number","defaultValue":120},{"id":"diastolic","label":"Diastolic (mmHg)","type":"number","defaultValue":80},{"id":"map","label":"Mean Arterial Pressure (MAP)","type":"computed","precision":1},{"id":"pulsePressure","label":"Pulse Pressure (mmHg)","type":"computed","precision":1},{"id":"categoryScore","label":"Category Score (1=normal to 5=crisis)","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Blood Pressure Reading","fields":["systolic","diastolic"]},{"id":"outputs","label":"Analysis","fields":["map","pulsePressure","categoryScore"]}],"formulas":{"map":"diastolic + (systolic - diastolic) / 3","pulsePressure":"systolic - diastolic","categoryScore":"systolic < 120 ? 1 : (systolic < 130 ? 2 : (systolic < 140 ? 3 : (systolic < 180 ? 4 : 5)))"},"examples":[{"label":"Normal 120/80","inputs":{"systolic":120,"diastolic":80}},{"label":"Elevated 128/82","inputs":{"systolic":128,"diastolic":82}},{"label":"High 145/95","inputs":{"systolic":145,"diastolic":95}}]}
