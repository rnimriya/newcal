{"id":"tdee-calculator","slug":"tdee-calculator","name":"TDEE Calculator","category":"health","icon":"🔥","description":"Calculate your Total Daily Energy Expenditure from BMR and activity level.","tags":["tdee","calories","maintenance","health"],"fields":[{"id":"weight","label":"Weight (kg)","type":"number","defaultValue":70},{"id":"height","label":"Height (cm)","type":"number","defaultValue":175},{"id":"age","label":"Age (years)","type":"number","defaultValue":30},{"id":"sex","label":"Sex (1=male, 0=female)","type":"number","defaultValue":1},{"id":"activity","label":"Activity Factor (1.2=sedentary, 1.375=light, 1.55=moderate, 1.725=active, 1.9=very active)","type":"number","defaultValue":1.55},{"id":"bmr","label":"BMR (Mifflin-St Jeor)","type":"computed","precision":1},{"id":"tdee","label":"TDEE (calories/day)","type":"computed","precision":1},{"id":"lossCalories","label":"For weight loss (−500 cal)","type":"computed","precision":1},{"id":"gainCalories","label":"For weight gain (+500 cal)","type":"computed","precision":1}],"groups":[{"id":"inputs","label":"Your Details","fields":["weight","height","age","sex","activity"]},{"id":"outputs","label":"Calorie Targets","fields":["bmr","tdee","lossCalories","gainCalories"]}],"formulas":{"bmr":"sex > 0 ? (10*weight + 6.25*height - 5*age + 5) : (10*weight + 6.25*height - 5*age - 161)","tdee":"(sex > 0 ? (10*weight + 6.25*height - 5*age + 5) : (10*weight + 6.25*height - 5*age - 161)) * activity","lossCalories":"(sex > 0 ? (10*weight + 6.25*height - 5*age + 5) : (10*weight + 6.25*height - 5*age - 161)) * activity - 500","gainCalories":"(sex > 0 ? (10*weight + 6.25*height - 5*age + 5) : (10*weight + 6.25*height - 5*age - 161)) * activity + 500"},"examples":[{"label":"30yo male 70kg 175cm moderate","inputs":{"weight":70,"height":175,"age":30,"sex":1,"activity":1.55}},{"label":"25yo female 60kg 165cm light active","inputs":{"weight":60,"height":165,"age":25,"sex":0,"activity":1.375}}]}
