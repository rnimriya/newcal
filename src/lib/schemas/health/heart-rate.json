{"id":"heart-rate-calculator","slug":"heart-rate-calculator","name":"Heart Rate Calculator","category":"health","icon":"❤️","description":"Find your maximum heart rate and training zones by age.","tags":["heart rate","training zones","cardio","health"],"fields":[{"id":"age","label":"Age (years)","type":"number","defaultValue":30},{"id":"restingHR","label":"Resting Heart Rate (bpm)","type":"number","defaultValue":65},{"id":"maxHR","label":"Max Heart Rate (bpm)","type":"computed","precision":0},{"id":"hrReserve","label":"Heart Rate Reserve (bpm)","type":"computed","precision":0},{"id":"zone1Low","label":"Zone 1 — Warm up (50–60%)","type":"computed","precision":0},{"id":"zone2Low","label":"Zone 2 — Fat burn (60–70%)","type":"computed","precision":0},{"id":"zone3Low","label":"Zone 3 — Aerobic (70–80%)","type":"computed","precision":0},{"id":"zone4Low","label":"Zone 4 — Anaerobic (80–90%)","type":"computed","precision":0},{"id":"zone5Low","label":"Zone 5 — Max effort (90–100%)","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Your Data","fields":["age","restingHR"]},{"id":"zones","label":"Training Zones (Karvonen)","fields":["maxHR","hrReserve","zone1Low","zone2Low","zone3Low","zone4Low","zone5Low"]}],"formulas":{"maxHR":"220 - age","hrReserve":"(220 - age) - restingHR","zone1Low":"floor(0.50 * ((220-age) - restingHR) + restingHR)","zone2Low":"floor(0.60 * ((220-age) - restingHR) + restingHR)","zone3Low":"floor(0.70 * ((220-age) - restingHR) + restingHR)","zone4Low":"floor(0.80 * ((220-age) - restingHR) + restingHR)","zone5Low":"floor(0.90 * ((220-age) - restingHR) + restingHR)"},"examples":[{"label":"30-year-old, RHR 65","inputs":{"age":30,"restingHR":65}},{"label":"45-year-old, RHR 70","inputs":{"age":45,"restingHR":70}}]}
