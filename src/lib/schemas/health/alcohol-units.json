{"id":"alcohol-units","slug":"alcohol-units","name":"Alcohol Units Calculator","category":"health","icon":"🍺","description":"Calculate alcohol units from drink volume and ABV. One unit = 10mL pure alcohol.","tags":["alcohol","units","abv","health"],"fields":[{"id":"volumeMl","label":"Volume (mL)","type":"number","defaultValue":500},{"id":"abv","label":"ABV %","type":"number","defaultValue":5},{"id":"drinks","label":"Number of Drinks","type":"number","defaultValue":1},{"id":"units","label":"Alcohol Units","type":"computed","precision":2},{"id":"totalUnits","label":"Total Units (all drinks)","type":"computed","precision":2},{"id":"calories","label":"Calories (approx)","type":"computed","precision":1},{"id":"hoursToSober","label":"Hours to Sober (est.)","type":"computed","precision":1}],"groups":[{"id":"inputs","label":"Drink Details","fields":["volumeMl","abv","drinks"]},{"id":"outputs","label":"Results","fields":["units","totalUnits","calories","hoursToSober"]}],"formulas":{"units":"volumeMl * abv / 1000","totalUnits":"volumeMl * abv / 1000 * drinks","calories":"volumeMl * abv / 100 * 7.1 * drinks","hoursToSober":"volumeMl * abv / 1000 * drinks / 1"},"examples":[{"label":"Pint of beer (500mL, 5%)","inputs":{"volumeMl":500,"abv":5,"drinks":1}},{"label":"Glass of wine (175mL, 13%)","inputs":{"volumeMl":175,"abv":13,"drinks":1}}]}
