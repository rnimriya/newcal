{"id":"pregnancy-due-date","slug":"pregnancy-due-date","name":"Pregnancy Due Date Calculator","category":"health","icon":"🤰","description":"Estimate pregnancy due date from last menstrual period (LMP) using Naegele's rule.","tags":["pregnancy","due date","lmp","health"],"fields":[{"id":"lmpYear","label":"LMP Year","type":"number","defaultValue":2025},{"id":"lmpMonth","label":"LMP Month","type":"number","defaultValue":1},{"id":"lmpDay","label":"LMP Day","type":"number","defaultValue":15},{"id":"cycleLength","label":"Cycle Length (days)","type":"number","defaultValue":28},{"id":"gestationDays","label":"Gestation (days from LMP)","type":"computed","precision":0},{"id":"eddDay","label":"Due Date Day (approx)","type":"computed","precision":0},{"id":"eddMonth","label":"Due Date Month","type":"computed","precision":0},{"id":"eddYear","label":"Due Date Year","type":"computed","precision":0},{"id":"conceptionDay","label":"Approx Conception Day","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Last Menstrual Period","fields":["lmpYear","lmpMonth","lmpDay","cycleLength"]},{"id":"outputs","label":"Due Date Estimate","fields":["gestationDays","eddYear","eddMonth","eddDay","conceptionDay"]}],"formulas":{"gestationDays":"280 + (cycleLength - 28)","conceptionDay":"lmpDay + 14","eddDay":"mod(lmpDay + 280 + (cycleLength - 28) - 1, 28) + 1","eddMonth":"mod(lmpMonth + floor((lmpDay + 280 + (cycleLength - 28)) / 30) - 1, 12) + 1","eddYear":"lmpYear + floor((lmpMonth + floor((lmpDay + 280 + (cycleLength - 28)) / 30) - 1) / 12)"},"examples":[{"label":"LMP Jan 15 2025","inputs":{"lmpYear":2025,"lmpMonth":1,"lmpDay":15,"cycleLength":28}},{"label":"LMP Mar 1 2025, 30-day cycle","inputs":{"lmpYear":2025,"lmpMonth":3,"lmpDay":1,"cycleLength":30}}]}
