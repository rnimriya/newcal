{"id":"body-fat-calculator","slug":"body-fat-calculator","name":"Body Fat Calculator","category":"health","icon":"📏","description":"Estimate body fat percentage using the US Navy circumference method.","tags":["body fat","body composition","health"],"fields":[{"id":"height","label":"Height (cm)","type":"number","defaultValue":175},{"id":"neck","label":"Neck circumference (cm)","type":"number","defaultValue":38},{"id":"waist","label":"Waist circumference (cm)","type":"number","defaultValue":85},{"id":"hip","label":"Hip circumference (cm, women only)","type":"number","defaultValue":95},{"id":"sex","label":"Sex (1=male, 0=female)","type":"number","defaultValue":1},{"id":"bodyFatPct","label":"Body Fat %","type":"computed","precision":2,"suffix":"%"},{"id":"fatMass","label":"Fat Mass (kg) at 70kg","type":"computed","precision":2},{"id":"leanMass","label":"Lean Mass (kg) at 70kg","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"Measurements","fields":["height","neck","waist","hip","sex"]},{"id":"outputs","label":"Results","fields":["bodyFatPct","fatMass","leanMass"]}],"formulas":{"bodyFatPct":"sex > 0 ? (495 / (1.0324 - 0.19077*log10(waist-neck) + 0.15456*log10(height)) - 450) : (495 / (1.29579 - 0.35004*log10(waist+hip-neck) + 0.22100*log10(height)) - 450)","fatMass":"70 * (sex > 0 ? (495 / (1.0324 - 0.19077*log10(waist-neck) + 0.15456*log10(height)) - 450) : (495 / (1.29579 - 0.35004*log10(waist+hip-neck) + 0.22100*log10(height)) - 450)) / 100","leanMass":"70 * (1 - (sex > 0 ? (495 / (1.0324 - 0.19077*log10(waist-neck) + 0.15456*log10(height)) - 450) : (495 / (1.29579 - 0.35004*log10(waist+hip-neck) + 0.22100*log10(height)) - 450)) / 100)"},"examples":[{"label":"Male measurements","inputs":{"height":175,"neck":38,"waist":85,"hip":95,"sex":1}},{"label":"Female measurements","inputs":{"height":165,"neck":33,"waist":75,"hip":100,"sex":0}}]}
