{"id":"vo2-max-calculator","slug":"vo2-max-calculator","name":"VO2 Max Calculator","category":"health","icon":"🫁","description":"Estimate VO2 max from resting and maximum heart rate using the Uth-Sørensen-Overgaard-Pedersen formula.","tags":["vo2 max","aerobic capacity","fitness","health"],"fields":[{"id":"maxHR","label":"Max Heart Rate (bpm)","type":"number","defaultValue":190},{"id":"restingHR","label":"Resting Heart Rate (bpm)","type":"number","defaultValue":60},{"id":"vo2Max","label":"VO2 Max (mL/kg/min)","type":"computed","precision":2},{"id":"fitnessLevel","label":"Fitness Score (×10)","type":"computed","precision":1},{"id":"o2PerMin","label":"O2 Capacity (mL/min, 70kg)","type":"computed","precision":1}],"groups":[{"id":"inputs","label":"Heart Rate Data","fields":["maxHR","restingHR"]},{"id":"outputs","label":"Results","fields":["vo2Max","fitnessLevel","o2PerMin"]}],"formulas":{"vo2Max":"15 * maxHR / restingHR","fitnessLevel":"15 * maxHR / restingHR * 10","o2PerMin":"15 * maxHR / restingHR * 70"},"examples":[{"label":"Recreational runner","inputs":{"maxHR":190,"restingHR":60}},{"label":"Trained athlete","inputs":{"maxHR":195,"restingHR":45}}]}
