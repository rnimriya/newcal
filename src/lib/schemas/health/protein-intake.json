{"id":"protein-intake-calculator","slug":"protein-intake-calculator","name":"Protein Intake Calculator","category":"health","icon":"🥩","description":"Calculate daily protein requirements based on weight and fitness goal.","tags":["protein","nutrition","intake","health"],"fields":[{"id":"weight","label":"Body Weight (kg)","type":"number","defaultValue":75},{"id":"activityLevel","label":"Activity (1=sedentary, 1.5=moderate, 2=athlete)","type":"number","defaultValue":1.5},{"id":"minProtein","label":"Minimum Protein (g/day)","type":"computed","precision":1},{"id":"optimalProtein","label":"Optimal Protein (g/day)","type":"computed","precision":1},{"id":"maxProtein","label":"Maximum (g/day)","type":"computed","precision":1},{"id":"proteinPerMeal","label":"Per Meal (3 meals)","type":"computed","precision":1}],"groups":[{"id":"inputs","label":"Your Details","fields":["weight","activityLevel"]},{"id":"outputs","label":"Protein Targets","fields":["minProtein","optimalProtein","maxProtein","proteinPerMeal"]}],"formulas":{"minProtein":"weight * 0.8","optimalProtein":"weight * 1.6 * activityLevel","maxProtein":"weight * 2.2 * activityLevel","proteinPerMeal":"weight * 1.6 * activityLevel / 3"},"examples":[{"label":"75kg moderate active","inputs":{"weight":75,"activityLevel":1.5}},{"label":"60kg athlete","inputs":{"weight":60,"activityLevel":2}}]}
