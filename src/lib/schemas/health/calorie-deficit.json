{"id":"calorie-deficit-calculator","slug":"calorie-deficit-calculator","name":"Calorie Deficit Calculator","category":"health","icon":"⚖️","description":"Calculate calorie deficit needed to reach your weight loss goal by a target date.","tags":["calorie deficit","weight loss","health"],"fields":[{"id":"currentWeight","label":"Current Weight (kg)","type":"number","defaultValue":80},{"id":"targetWeight","label":"Target Weight (kg)","type":"number","defaultValue":75},{"id":"weeks","label":"Weeks to Goal","type":"number","defaultValue":10},{"id":"tdee","label":"Your TDEE (calories/day)","type":"number","defaultValue":2200},{"id":"weightToLose","label":"Weight to Lose (kg)","type":"computed","precision":2},{"id":"dailyDeficit","label":"Required Daily Deficit (cal)","type":"computed","precision":1},{"id":"targetCalories","label":"Daily Calorie Target","type":"computed","precision":1},{"id":"weeklyLoss","label":"Weekly Weight Loss (kg)","type":"computed","precision":3}],"groups":[{"id":"inputs","label":"Goal Details","fields":["currentWeight","targetWeight","weeks","tdee"]},{"id":"outputs","label":"Plan","fields":["weightToLose","dailyDeficit","targetCalories","weeklyLoss"]}],"formulas":{"weightToLose":"currentWeight - targetWeight","dailyDeficit":"(currentWeight - targetWeight) * 7700 / (weeks * 7)","targetCalories":"tdee - (currentWeight - targetWeight) * 7700 / (weeks * 7)","weeklyLoss":"(currentWeight - targetWeight) / weeks"},"examples":[{"label":"5kg in 10 weeks","inputs":{"currentWeight":80,"targetWeight":75,"weeks":10,"tdee":2200}},{"label":"10kg in 20 weeks","inputs":{"currentWeight":90,"targetWeight":80,"weeks":20,"tdee":2400}}]}
