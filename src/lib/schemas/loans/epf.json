{"id":"epf","slug":"epf-calculator","name":"EPF Calculator","category":"loans","icon":"🏦","description":"Calculate Employee Provident Fund (EPF) monthly contribution and annual balance for Indian employees.","tags":["EPF","employee provident fund","India","loans","retirement"],"fields":[{"id":"basicSalary","label":"Basic + DA Salary (₹/month)","type":"number","defaultValue":25000,"constraint":{"min":1000,"step":500}},{"id":"years","label":"Years of Service","type":"number","defaultValue":10,"constraint":{"min":1,"max":40,"step":1}},{"id":"interestRate","label":"Interest Rate (% p.a.)","type":"number","defaultValue":8.15,"constraint":{"min":1,"max":15,"step":0.05}},{"id":"employeeContrib","label":"Employee Contribution (₹/month)","type":"computed","precision":2,"helpText":"12% of Basic"},{"id":"employerContrib","label":"Employer Contribution (₹/month)","type":"computed","precision":2,"helpText":"3.67% to EPF"},{"id":"totalMonthly","label":"Total Monthly Contribution (₹)","type":"computed","precision":2},{"id":"corpusPFY","label":"Estimated Corpus after years (₹)","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"Salary Details","fields":["basicSalary","years","interestRate"]},{"id":"outputs","label":"Contributions","fields":["employeeContrib","employerContrib","totalMonthly","corpusPFY"]}],"formulas":{"employeeContrib":"basicSalary * 0.12","employerContrib":"basicSalary * 0.0367","totalMonthly":"basicSalary * 0.12 + basicSalary * 0.0367","corpusPFY":"(basicSalary * 0.12 + basicSalary * 0.0367) * 12 * ((1 + interestRate/100)^years - 1) / (interestRate/100) * (1 + interestRate/100)"},"examples":[{"label":"₹25,000 basic, 10 years","inputs":{"basicSalary":25000,"years":10,"interestRate":8.15}},{"label":"₹50,000 basic, 20 years","inputs":{"basicSalary":50000,"years":20,"interestRate":8.15}}]}
