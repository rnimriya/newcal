{"id":"mutual-fund-returns","slug":"mutual-fund-returns","name":"Mutual Fund Returns Calculator","category":"loans","icon":"📈","description":"Calculate mutual fund returns from NAV change. Find absolute return, CAGR, and XIRR estimate.","tags":["mutual fund","returns","NAV","CAGR","loans"],"fields":[{"id":"purchaseNAV","label":"Purchase NAV (₹)","type":"number","defaultValue":25,"constraint":{"min":0.01,"step":0.01}},{"id":"currentNAV","label":"Current NAV (₹)","type":"number","defaultValue":40},{"id":"units","label":"Units Held","type":"number","defaultValue":1000,"constraint":{"min":1,"step":1}},{"id":"holdingYears","label":"Holding Period (years)","type":"number","defaultValue":3,"constraint":{"min":0.1,"max":50,"step":0.1}},{"id":"investedAmount","label":"Amount Invested (₹)","type":"computed","precision":2},{"id":"currentValue","label":"Current Value (₹)","type":"computed","precision":2},{"id":"absoluteReturn","label":"Absolute Return (%)","type":"computed","precision":2},{"id":"cagr","label":"CAGR (%)","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Fund Details","fields":["purchaseNAV","currentNAV","units","holdingYears"]},{"id":"outputs","label":"Returns","fields":["investedAmount","currentValue","absoluteReturn","cagr"]}],"formulas":{"investedAmount":"purchaseNAV * units","currentValue":"currentNAV * units","absoluteReturn":"(currentNAV - purchaseNAV) / purchaseNAV * 100","cagr":"((currentNAV / purchaseNAV)^(1/holdingYears) - 1) * 100"},"examples":[{"label":"NAV 25 → 40, 1000 units, 3 years","inputs":{"purchaseNAV":25,"currentNAV":40,"units":1000,"holdingYears":3}},{"label":"NAV 10 → 25, 500 units, 5 years","inputs":{"purchaseNAV":10,"currentNAV":25,"units":500,"holdingYears":5}}]}
