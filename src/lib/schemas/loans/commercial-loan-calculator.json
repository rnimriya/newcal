{
  "id": "commercial-loan",
  "slug": "commercial-loan-calculator",
  "name": "Commercial Loan Calculator",
  "category": "loans",
  "description": "Calculate commercial loan payments, total interest, and balloon payment for business financing.",
  "icon": "🏢",
  "tags": ["commercial loan", "business loan", "balloon payment", "amortization", "mortgage"],
  "fields": [
    { "id": "loanAmount", "label": "Loan Amount", "type": "number", "defaultValue": 500000, "prefix": "$", "constraint": { "min": 10000, "step": 10000, "required": true } },
    { "id": "annualInterestRate", "label": "Annual Interest Rate", "type": "number", "defaultValue": 7.5, "suffix": "%", "constraint": { "min": 0.1, "max": 30, "step": 0.05, "required": true } },
    { "id": "termYears", "label": "Amortization Term (Years)", "type": "number", "defaultValue": 25, "constraint": { "min": 1, "max": 50, "step": 1, "required": true } },
    { "id": "balloonYears", "label": "Balloon Payment Due (Years)", "type": "number", "defaultValue": 10, "constraint": { "min": 1, "max": 50, "step": 1, "required": true } },
    { "id": "monthlyPayment", "label": "Monthly Payment", "type": "computed", "precision": 2, "prefix": "$" },
    { "id": "totalInterest", "label": "Total Interest (Full Term)", "type": "computed", "precision": 2, "prefix": "$" },
    { "id": "balloonPayment", "label": "Balloon Payment", "type": "computed", "precision": 2, "prefix": "$" }
  ],
  "groups": [
    { "id": "inputs", "label": "Loan Parameters", "fields": ["loanAmount", "annualInterestRate", "termYears", "balloonYears"] },
    { "id": "outputs", "label": "Loan Results", "fields": ["monthlyPayment", "totalInterest", "balloonPayment"] }
  ],
  "formulas": {
    "monthlyPayment": "loanAmount * (annualInterestRate/1200) * (1 + annualInterestRate/1200)^(termYears*12) / ((1 + annualInterestRate/1200)^(termYears*12) - 1)",
    "totalInterest": "monthlyPayment * termYears * 12 - loanAmount",
    "balloonPayment": "loanAmount * (1 + annualInterestRate/1200)^(balloonYears*12) - monthlyPayment * ((1 + annualInterestRate/1200)^(balloonYears*12) - 1) / (annualInterestRate/1200)"
  },
  "examples": [
    { "label": "Office building loan", "inputs": { "loanAmount": 500000, "annualInterestRate": 7.5, "termYears": 25, "balloonYears": 10 } },
    { "label": "Retail space", "inputs": { "loanAmount": 1000000, "annualInterestRate": 7.0, "termYears": 20, "balloonYears": 5 } },
    { "label": "Small business", "inputs": { "loanAmount": 250000, "annualInterestRate": 8.0, "termYears": 15, "balloonYears": 7 } }
  ],
  "explanation": "Commercial loans typically have a shorter loan term than the amortization period, resulting in a balloon payment due at the end of the loan term. Monthly payments are calculated based on the full amortization schedule, but the remaining principal balance becomes due as a lump-sum balloon payment at the specified year."
}
