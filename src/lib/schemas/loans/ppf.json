{"id":"ppf","slug":"ppf-calculator","name":"PPF Calculator","category":"loans","icon":"🏦","description":"Calculate Public Provident Fund (PPF) maturity amount. 15-year lock-in with current 7.1% interest.","tags":["PPF","public provident fund","India","loans","savings"],"fields":[{"id":"yearlyInvestment","label":"Yearly Investment (₹)","type":"number","defaultValue":150000,"constraint":{"min":500,"max":150000,"step":500}},{"id":"interestRate","label":"Interest Rate (%)","type":"number","defaultValue":7.1,"constraint":{"min":1,"max":15,"step":0.1}},{"id":"years","label":"Lock-in Period (years)","type":"number","defaultValue":15,"constraint":{"min":15,"max":50,"step":1}},{"id":"totalInvested","label":"Total Invested (₹)","type":"computed","precision":2},{"id":"maturityAmount","label":"Maturity Amount (₹)","type":"computed","precision":2},{"id":"totalInterest","label":"Total Interest Earned (₹)","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"PPF Details","fields":["yearlyInvestment","interestRate","years"]},{"id":"outputs","label":"Returns","fields":["totalInvested","maturityAmount","totalInterest"]}],"formulas":{"totalInvested":"yearlyInvestment * years","maturityAmount":"yearlyInvestment * ((1 + interestRate/100)^years - 1) / (interestRate/100) * (1 + interestRate/100)","totalInterest":"yearlyInvestment * ((1 + interestRate/100)^years - 1) / (interestRate/100) * (1 + interestRate/100) - yearlyInvestment * years"},"examples":[{"label":"₹1.5L/year at 7.1% for 15 years","inputs":{"yearlyInvestment":150000,"interestRate":7.1,"years":15}},{"label":"Extended 25 years","inputs":{"yearlyInvestment":150000,"interestRate":7.1,"years":25}}]}
