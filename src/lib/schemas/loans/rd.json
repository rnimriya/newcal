{"id":"rd","slug":"rd-calculator","name":"RD Calculator","category":"loans","icon":"📆","description":"Calculate Recurring Deposit maturity amount with compound interest.","tags":["RD","recurring deposit","savings","loans","India"],"fields":[{"id":"monthlyDeposit","label":"Monthly Deposit (₹)","type":"number","defaultValue":5000,"constraint":{"min":100,"step":100}},{"id":"rate","label":"Interest Rate (% p.a.)","type":"number","defaultValue":6.5,"constraint":{"min":1,"max":15,"step":0.1}},{"id":"months","label":"Tenure (months)","type":"number","defaultValue":36,"constraint":{"min":3,"max":120,"step":1}},{"id":"totalDeposited","label":"Total Deposited (₹)","type":"computed","precision":2},{"id":"maturityAmount","label":"Maturity Amount (₹)","type":"computed","precision":2},{"id":"interestEarned","label":"Interest Earned (₹)","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"RD Details","fields":["monthlyDeposit","rate","months"]},{"id":"outputs","label":"Returns","fields":["totalDeposited","maturityAmount","interestEarned"]}],"formulas":{"totalDeposited":"monthlyDeposit * months","maturityAmount":"monthlyDeposit * ((1 + rate/400)^(4*months/12) - 1) / (1 - (1 + rate/400)^(-1/3))","interestEarned":"monthlyDeposit * ((1 + rate/400)^(4*months/12) - 1) / (1 - (1 + rate/400)^(-1/3)) - monthlyDeposit * months"},"examples":[{"label":"₹5000/month, 6.5% for 36 months","inputs":{"monthlyDeposit":5000,"rate":6.5,"months":36}},{"label":"₹10000/month, 7% for 60 months","inputs":{"monthlyDeposit":10000,"rate":7,"months":60}}]}
