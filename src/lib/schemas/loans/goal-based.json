{
  "id": "goal-based",
  "slug": "goal-based-calculator",
  "name": "Goal Based Calculator",
  "category": "loans",
  "icon": "🎯",
  "description": "Calculate the required monthly savings to achieve your financial target, adjusted for future inflation.",
  "tags": [
    "goal planning",
    "savings",
    "inflation",
    "investment",
    "loans"
  ],
  "fields": [
    {
      "id": "targetAmount",
      "label": "Target Goal (today's money) (₹)",
      "type": "number",
      "defaultValue": 1000000,
      "constraint": {
        "min": 1000,
        "step": 1000
      }
    },
    {
      "id": "years",
      "label": "Years to Target",
      "type": "number",
      "defaultValue": 5,
      "constraint": {
        "min": 1,
        "max": 50,
        "step": 1
      }
    },
    {
      "id": "inflationRate",
      "label": "Annual Inflation Rate (%)",
      "type": "number",
      "defaultValue": 6,
      "constraint": {
        "min": 0,
        "max": 20,
        "step": 0.5
      }
    },
    {
      "id": "expectedReturn",
      "label": "Expected Annual Return (%)",
      "type": "number",
      "defaultValue": 12,
      "constraint": {
        "min": 0.1,
        "max": 50,
        "step": 0.1
      }
    },
    {
      "id": "inflationAdjustedGoal",
      "label": "Future Goal (Inflation Adjusted) (₹)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "requiredSIP",
      "label": "Required Monthly SIP (₹)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "totalInvested",
      "label": "Total Amount Invested (₹)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "wealthGain",
      "label": "Wealth Gained (₹)",
      "type": "computed",
      "precision": 2
    }
  ],
  "groups": [
    {
      "id": "inputs",
      "label": "Details",
      "fields": [
        "targetAmount",
        "years",
        "inflationRate",
        "expectedReturn"
      ]
    },
    {
      "id": "outputs",
      "label": "Outputs",
      "fields": [
        "inflationAdjustedGoal",
        "requiredSIP",
        "totalInvested",
        "wealthGain"
      ]
    }
  ],
  "formulas": {
    "inflationAdjustedGoal": "targetAmount * (1 + inflationRate/100)^years",
    "requiredSIP": "inflationAdjustedGoal / (((1 + expectedReturn/1200)^(years * 12) - 1) / (expectedReturn/1200) * (1 + expectedReturn/1200))",
    "totalInvested": "requiredSIP * years * 12",
    "wealthGain": "inflationAdjustedGoal - totalInvested"
  },
  "examples": [
    {
      "label": "Example Values",
      "inputs": {
        "targetAmount": 1000000,
        "years": 5,
        "inflationRate": 6,
        "expectedReturn": 12
      }
    }
  ]
}