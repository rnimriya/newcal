{
  "id": "elss",
  "slug": "elss-calculator",
  "name": "ELSS Calculator",
  "category": "loans",
  "icon": "🛡️",
  "description": "Calculate returns and tax savings on Equity Linked Savings Scheme (ELSS) mutual funds under Section 80C.",
  "tags": [
    "elss",
    "tax saving",
    "80c",
    "mutual fund",
    "loans"
  ],
  "fields": [
    {
      "id": "investment",
      "label": "Investment Amount (₹)",
      "type": "number",
      "defaultValue": 100000,
      "constraint": {
        "min": 500,
        "step": 500
      }
    },
    {
      "id": "expectedReturn",
      "label": "Expected Annual Return (%)",
      "type": "number",
      "defaultValue": 12,
      "constraint": {
        "min": 0.1,
        "max": 50,
        "step": 0.1
      }
    },
    {
      "id": "years",
      "label": "Holding Period (years)",
      "type": "number",
      "defaultValue": 3,
      "constraint": {
        "min": 3,
        "max": 30,
        "step": 1
      }
    },
    {
      "id": "taxSlab",
      "label": "Your Tax Slab (%)",
      "type": "number",
      "defaultValue": 30,
      "constraint": {
        "min": 0,
        "max": 50,
        "step": 5
      }
    },
    {
      "id": "maturityAmount",
      "label": "Maturity Amount (₹)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "wealthGain",
      "label": "Wealth Gained (₹)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "taxSaved",
      "label": "Tax Saved under Sec 80C (₹)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "totalBenefit",
      "label": "Total Financial Benefit (₹)",
      "type": "computed",
      "precision": 2
    }
  ],
  "groups": [
    {
      "id": "inputs",
      "label": "Details",
      "fields": [
        "investment",
        "expectedReturn",
        "years",
        "taxSlab"
      ]
    },
    {
      "id": "outputs",
      "label": "Outputs",
      "fields": [
        "maturityAmount",
        "wealthGain",
        "taxSaved",
        "totalBenefit"
      ]
    }
  ],
  "formulas": {
    "maturityAmount": "investment * (1 + expectedReturn/100)^years",
    "wealthGain": "maturityAmount - investment",
    "taxSaved": "min(investment, 150000) * taxSlab / 100",
    "totalBenefit": "wealthGain + taxSaved"
  },
  "examples": [
    {
      "label": "Example Values",
      "inputs": {
        "investment": 100000,
        "expectedReturn": 12,
        "years": 3,
        "taxSlab": 30
      }
    }
  ]
}