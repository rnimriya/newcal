{"id":"fd","slug":"fd-calculator","name":"Fixed Deposit (FD) Calculator","category":"loans","icon":"🏦","description":"Calculate FD maturity amount with compound interest. Compare quarterly vs annual compounding.","tags":["FD","fixed deposit","compound interest","loans","India"],"fields":[{"id":"principal","label":"Principal Amount (₹)","type":"number","defaultValue":100000,"constraint":{"min":1000,"step":1000}},{"id":"rate","label":"Interest Rate (% p.a.)","type":"number","defaultValue":7,"constraint":{"min":0.1,"max":20,"step":0.1}},{"id":"years","label":"Period (years)","type":"number","defaultValue":3,"constraint":{"min":0.25,"max":30,"step":0.25}},{"id":"maturityAnnual","label":"Maturity (Annual compounding)","type":"computed","precision":2},{"id":"maturityQuarterly","label":"Maturity (Quarterly compounding)","type":"computed","precision":2},{"id":"interestEarned","label":"Interest Earned (annual, ₹)","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"FD Details","fields":["principal","rate","years"]},{"id":"outputs","label":"Returns","fields":["maturityAnnual","maturityQuarterly","interestEarned"]}],"formulas":{"maturityAnnual":"principal * (1 + rate/100)^years","maturityQuarterly":"principal * (1 + rate/400)^(years*4)","interestEarned":"principal * (1 + rate/100)^years - principal"},"examples":[{"label":"₹1L at 7% for 3 years","inputs":{"principal":100000,"rate":7,"years":3}},{"label":"₹5L at 8% for 5 years","inputs":{"principal":500000,"rate":8,"years":5}}]}
