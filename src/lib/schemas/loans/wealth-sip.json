{
  "id": "wealth-sip",
  "slug": "wealth-sip-calculator",
  "name": "Wealth SIP Calculator",
  "category": "loans",
  "icon": "💰",
  "description": "Calculate the monthly Systematic Investment Plan (SIP) needed to reach your target wealth goal.",
  "tags": [
    "wealth sip",
    "sip",
    "goal planner",
    "mutual fund",
    "loans"
  ],
  "fields": [
    {
      "id": "targetWealth",
      "label": "Target Wealth (₹)",
      "type": "number",
      "defaultValue": 10000000,
      "constraint": {
        "min": 1000,
        "step": 1000
      }
    },
    {
      "id": "expectedReturn",
      "label": "Expected Annual Return (%)",
      "type": "number",
      "defaultValue": 12,
      "constraint": {
        "min": 0.1,
        "max": 50,
        "step": 0.1
      }
    },
    {
      "id": "years",
      "label": "Investment Period (years)",
      "type": "number",
      "defaultValue": 10,
      "constraint": {
        "min": 1,
        "max": 50,
        "step": 1
      }
    },
    {
      "id": "requiredSIP",
      "label": "Required Monthly SIP (₹)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "totalInvested",
      "label": "Total Amount Invested (₹)",
      "type": "computed",
      "precision": 2
    },
    {
      "id": "wealthGain",
      "label": "Wealth Gained (₹)",
      "type": "computed",
      "precision": 2
    }
  ],
  "groups": [
    {
      "id": "inputs",
      "label": "Details",
      "fields": [
        "targetWealth",
        "expectedReturn",
        "years"
      ]
    },
    {
      "id": "outputs",
      "label": "Outputs",
      "fields": [
        "requiredSIP",
        "totalInvested",
        "wealthGain"
      ]
    }
  ],
  "formulas": {
    "requiredSIP": "targetWealth / (((1 + expectedReturn/1200)^(years * 12) - 1) / (expectedReturn/1200) * (1 + expectedReturn/1200))",
    "totalInvested": "requiredSIP * years * 12",
    "wealthGain": "targetWealth - totalInvested"
  },
  "examples": [
    {
      "label": "Example Values",
      "inputs": {
        "targetWealth": 10000000,
        "expectedReturn": 12,
        "years": 10
      }
    }
  ]
}