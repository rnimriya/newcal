{"id":"gst","slug":"gst-calculator","name":"GST Calculator","category":"loans","icon":"🧾","description":"Calculate GST (Goods and Services Tax) for India. Add GST to find final price or remove GST from inclusive price.","tags":["GST","goods and services tax","India","tax","loans"],"fields":[{"id":"amount","label":"Amount (₹)","type":"number","defaultValue":1000,"constraint":{"min":0,"step":0.01}},{"id":"gstRate","label":"GST Rate (%)","type":"number","defaultValue":18,"constraint":{"min":0,"max":100,"step":0.1}},{"id":"gstAmount","label":"GST Amount (₹)","type":"computed","precision":2},{"id":"totalWithGST","label":"Total with GST (₹)","type":"computed","precision":2},{"id":"originalFromInclusive","label":"Original Price if GST-inclusive (₹)","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"Amount & Rate","fields":["amount","gstRate"]},{"id":"outputs","label":"GST Breakdown","fields":["gstAmount","totalWithGST","originalFromInclusive"]}],"formulas":{"gstAmount":"amount * gstRate / 100","totalWithGST":"amount * (1 + gstRate/100)","originalFromInclusive":"amount / (1 + gstRate/100)"},"examples":[{"label":"₹1000 at 18% GST","inputs":{"amount":1000,"gstRate":18}},{"label":"₹5000 at 28% GST","inputs":{"amount":5000,"gstRate":28}}]}
