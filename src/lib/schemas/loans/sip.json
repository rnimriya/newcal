{"id":"sip","slug":"sip-calculator","name":"SIP Calculator","category":"loans","icon":"📈","description":"Calculate returns on Systematic Investment Plan (SIP). Find maturity amount and wealth gained over time.","tags":["SIP","systematic investment","mutual fund","loans","India"],"fields":[{"id":"monthlyAmount","label":"Monthly Investment (₹)","type":"number","defaultValue":5000,"constraint":{"min":1,"step":100}},{"id":"expectedReturn","label":"Expected Annual Return (%)","type":"number","defaultValue":12,"constraint":{"min":0.1,"max":50,"step":0.1}},{"id":"years","label":"Investment Period (years)","type":"number","defaultValue":10,"constraint":{"min":1,"max":50,"step":1}},{"id":"months","label":"Total Months","type":"computed","precision":0},{"id":"totalInvested","label":"Total Amount Invested (₹)","type":"computed","precision":2},{"id":"maturityAmount","label":"Maturity Amount (₹)","type":"computed","precision":2},{"id":"wealthGain","label":"Wealth Gained (₹)","type":"computed","precision":2}],"groups":[{"id":"inputs","label":"SIP Details","fields":["monthlyAmount","expectedReturn","years"]},{"id":"outputs","label":"Returns","fields":["months","totalInvested","maturityAmount","wealthGain"]}],"formulas":{"months":"years * 12","totalInvested":"monthlyAmount * years * 12","maturityAmount":"monthlyAmount * ((1 + expectedReturn/1200)^(years*12) - 1) / (expectedReturn/1200) * (1 + expectedReturn/1200)","wealthGain":"monthlyAmount * ((1 + expectedReturn/1200)^(years*12) - 1) / (expectedReturn/1200) * (1 + expectedReturn/1200) - monthlyAmount * years * 12"},"examples":[{"label":"₹5000/month, 12%, 10 years","inputs":{"monthlyAmount":5000,"expectedReturn":12,"years":10}},{"label":"₹10000/month, 15%, 20 years","inputs":{"monthlyAmount":10000,"expectedReturn":15,"years":20}}]}
