{"id":"swp","slug":"swp-calculator","name":"SWP Calculator","category":"loans","icon":"💸","description":"Calculate Systematic Withdrawal Plan — how long your corpus lasts with monthly withdrawals.","tags":["SWP","systematic withdrawal","mutual fund","loans","India"],"fields":[{"id":"corpus","label":"Initial Corpus (₹)","type":"number","defaultValue":5000000,"constraint":{"min":10000,"step":10000}},{"id":"monthlyWithdrawal","label":"Monthly Withdrawal (₹)","type":"number","defaultValue":30000,"constraint":{"min":100,"step":500}},{"id":"expectedReturn","label":"Expected Annual Return (%)","type":"number","defaultValue":10,"constraint":{"min":0.1,"max":30,"step":0.1}},{"id":"monthsLasting","label":"Approx Months it Lasts","type":"computed","precision":0},{"id":"yearsLasting","label":"Approx Years it Lasts","type":"computed","precision":1},{"id":"totalWithdrawn","label":"Total Withdrawable (₹)","type":"computed","precision":0},{"id":"annualReturn","label":"Annual Return on Corpus (₹)","type":"computed","precision":0}],"groups":[{"id":"inputs","label":"SWP Details","fields":["corpus","monthlyWithdrawal","expectedReturn"]},{"id":"outputs","label":"Results","fields":["monthsLasting","yearsLasting","totalWithdrawn","annualReturn"]}],"formulas":{"monthsLasting":"log(monthlyWithdrawal / (monthlyWithdrawal - corpus * expectedReturn / 1200)) / log(1 + expectedReturn / 1200)","yearsLasting":"log(monthlyWithdrawal / (monthlyWithdrawal - corpus * expectedReturn / 1200)) / log(1 + expectedReturn / 1200) / 12","totalWithdrawn":"monthlyWithdrawal * log(monthlyWithdrawal / (monthlyWithdrawal - corpus * expectedReturn / 1200)) / log(1 + expectedReturn / 1200)","annualReturn":"corpus * expectedReturn / 100"},"examples":[{"label":"₹50L corpus, ₹30K/month at 10%","inputs":{"corpus":5000000,"monthlyWithdrawal":30000,"expectedReturn":10}},{"label":"₹1Cr corpus, ₹50K/month at 12%","inputs":{"corpus":10000000,"monthlyWithdrawal":50000,"expectedReturn":12}}]}
