{"id":"lumpsum","slug":"lumpsum-calculator","name":"Lumpsum Calculator","category":"loans","icon":"💰","description":"Calculate returns on a one-time lumpsum mutual fund investment with annual compounding.","tags":["lumpsum","mutual fund","investment","loans","India"],"fields":[{"id":"investment","label":"Investment Amount (₹)","type":"number","defaultValue":100000,"constraint":{"min":1000,"step":1000}},{"id":"expectedReturn","label":"Expected Annual Return (%)","type":"number","defaultValue":12,"constraint":{"min":0.1,"max":50,"step":0.1}},{"id":"years","label":"Investment Period (years)","type":"number","defaultValue":10,"constraint":{"min":1,"max":50,"step":1}},{"id":"maturityAmount","label":"Maturity Amount (₹)","type":"computed","precision":2},{"id":"wealthGain","label":"Wealth Gained (₹)","type":"computed","precision":2},{"id":"cagr","label":"CAGR (%)","type":"computed","precision":4}],"groups":[{"id":"inputs","label":"Investment Details","fields":["investment","expectedReturn","years"]},{"id":"outputs","label":"Returns","fields":["maturityAmount","wealthGain","cagr"]}],"formulas":{"maturityAmount":"investment * (1 + expectedReturn/100)^years","wealthGain":"investment * (1 + expectedReturn/100)^years - investment","cagr":"expectedReturn"},"examples":[{"label":"₹1L at 12% for 10 years","inputs":{"investment":100000,"expectedReturn":12,"years":10}},{"label":"₹5L at 15% for 20 years","inputs":{"investment":500000,"expectedReturn":15,"years":20}}]}
